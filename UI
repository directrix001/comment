def copy_master_sheet(file_path_1, file_path_2, password):
    try:
        # Read the 'Master' sheet from file_path_1 using pandas
        df = pd.read_excel(file_path_1, sheet_name='Master', engine='openpyxl')
        
        # Load the workbook from file_path_2 with write access
        wb2 = load_workbook(file_path_2, read_only=False)
        
        # Set workbook protection with a password
        wb2.security = WorkbookProtection(workbookPassword=password, lockStructure=True)
        
       
        # Create a new sheet named 'Master' in file_path_2
        new_master_sheet = wb2.create_sheet(title='Master')
        
        # Add a blank row before writing the DataFrame values
        blank_row_index = 1
        
        # Write column headers to the new 'Master' sheet
        for c_idx, column_name in enumerate(df.columns):
            new_master_sheet.cell(row=1, column=c_idx + 1, value=column_name)
        
        # Write the DataFrame values to the new 'Master' sheet starting after the blank row and column headers
        for r_idx, row in df.iterrows():
            for c_idx, value in enumerate(row):
                new_master_sheet.cell(row=r_idx + 2, column=c_idx + 1, value=value)
        
        # Save the changes to file_path_2
        wb2.save(file_path_2)
    except Exception as e:
        # Log and display error message
        logging.info(f"Calculation not completed.")
        log_step("Calculation not completed ,please re-run after correcting the error", 'error')
        # logging.info("Calculation not completed successfully.")
        logging.info(f"An error occurred: {str(e)}")
        var_failure=True
        progress_bar.stop()
        save_message_label.config(
            text=f"Error: {str(e)}",
            fg="red"
        )       



def copy_excel_file(source_path, destination_folder):
    try:
        # Verify if the source file exists
        if not os.path.exists(source_path):
            raise FileNotFoundError("The specified source file does not exist.")
        
        # Ensure the destination folder exists
        if not os.path.exists(destination_folder):
            os.makedirs(destination_folder)
        
        # Extract the file name from the source path
        file_name = os.path.basename(source_path)
        
        # Initialize destination path
        destination_path = os.path.join(destination_folder, file_name)
        
        # Check if a file with the same name already exists and modify the file name if necessary
        base_name, extension = os.path.splitext(file_name)
        counter = 1
        while os.path.exists(destination_path):
            destination_path = os.path.join(destination_folder, f"{base_name}_{counter}{extension}")
            counter += 1
        
        # Copy the file to the destination folder
        shutil.copy2(source_path, destination_path)
        
        print(f"File copied successfully to {destination_path}")
        
        # Return the path of the copied file
        return destination_path
    
    except Exception as e:
        print(f"An error occurred: {e}")
        return None




