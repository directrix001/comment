def update_elapsed_time():
    start_time = time.time()
    while not stop_thread:
        elapsed_seconds = int(time.time() - start_time)
        minutes, seconds = divmod(elapsed_seconds, 60)
        elapsed_time_label.config(text=f"Elapsed Time: {minutes:02d}:{seconds:02d}")

        time.sleep(0.5)  # Update every half second


def load_converter_data():
    try:
        # Construct file path
        file_path = os.path.join(os.getcwd(), 'Mandatory_folder', 'currency_converter.xlsx').replace("\\", "/")
        reset_action_1()
        
        # Read the Excel file
        df = pd.read_excel(file_path)
        
        # Get current year and month index
        current_year = pd.Timestamp.now().year
        month_index = month_dropdown.current() + 1
        
        # Check if data exists for the selected month and year
        if not pd.isna(df.iloc[0, month_index]):
            converter_var_entry.insert(0, df.iloc[0, month_index])
            messagebox.showinfo("Data Info", f"Please check this data is coming from our database for {month_dropdown.get()} {df.iloc[0, 0]}.")
        else:
            messagebox.showinfo("Data Input", f"No data available for {month_dropdown.get()} {df.iloc[0, 0]}. Please enter a value in the entry field.")
            
            # Wait for user input in the entry field
            root.wait_variable(converter_var_entry)

            # Retrieve user input from entry field
            user_input = converter_var_entry.get()
            
            
            try:
                # Convert input to float and update DataFrame
                df.at[0, month_index] = float(user_input)
                
                # Save updated DataFrame back to Excel file
                df.to_excel(file_path, index=False)
                
                messagebox.showinfo("Update Success", f"Data for {month_dropdown.get()} {df.iloc[0, 0]} has been updated successfully.")
            except ValueError:
                messagebox.showerror("Invalid Input", "Please enter a valid number.")
    except Exception as e:
        messagebox.showerror("Error", f"Failed to load converter data: {e}")


