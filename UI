def read_xlsx_openpyxl(path: str,
                       sheet_name=None,
                       password: str | None = None,
                       return_all_sheets: bool = False):
    try:                   

        if not os.path.isfile(path):
            raise FileNotFoundError(f"Excel file not found: {path}")

        # Only support OOXML formats here
        ext = os.path.splitext(path)[1].lower()
        if ext not in (".xlsx", ".xlsm"):
            raise ValueError(f"Unsupported extension for openpyxl: {ext}. Use .xlsx/.xlsm.")

        # Fix any HTML-escaped ampersands that might slip in from a UI
        if isinstance(sheet_name, str):
            sheet_name = sheet_name.replace("&amp;", "&")

        # Check encryption first
        with open(path, "rb") as f:
            office_file = msoffcrypto.OfficeFile(f)
            is_encrypted = getattr(office_file, "is_encrypted", False)

            if is_encrypted:
                if not password:
                    raise ValueError("This workbook is encrypted. Provide `password=` to open it.")
                # Decrypt into memory
                buf = io.BytesIO()
                office_file.load_key(password=password)  # you can add verify_password=True if needed
                office_file.decrypt(buf)
                buf.seek(0)

                # Read with openpyxl from the decrypted buffer
                return pd.read_excel(
                    buf,
                    sheet_name=(None if return_all_sheets else sheet_name),
                    engine="openpyxl"
                )
            else:
                # Not encrypted: read directly with openpyxl
                return pd.read_excel(
                    path,
                    sheet_name=(None if return_all_sheets else sheet_name),
                    engine="openpyxl"
                )
    except Exception as e:
        # Log and display error message
        logging.info(f"Calculation not completed.")
        log_step("Calculation not completed ,please re-run after correcting the error", 'error')
        # logging.info("Calculation not completed successfully.")
        logging.info(f"An error occurred: {str(e)}")
        var_failure=True
        progress_bar.stop()
        save_message_label.config(
            text=f"Error: {str(e)}",
            fg="red"
        )       
            


