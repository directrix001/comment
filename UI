def determine_fiscal_year(selected_month):
    logging.info("Checking for valid Month.")
    current_year = time.localtime().tm_year
    fiscal_year_start_month = 4  # April is the start of the fiscal year
    if selected_month < fiscal_year_start_month:
        fiscal_year = current_year - 1
    else:
        fiscal_year = current_year
    return fiscal_year



