_chat_history: dict[str, deque] = {}

def get_history(session_id: str, max_turns: int = 10) -> list:
    if session_id not in _chat_history:
        _chat_history[session_id] = deque(maxlen=max_turns * 2)
    return list(_chat_history[session_id])

def save_turn(session_id: str, question: str, answer: str, max_turns: int = 10):
    if session_id not in _chat_history:
        _chat_history[session_id] = deque(maxlen=max_turns * 2)
    _chat_history[session_id].append(HumanMessage(content=question))
    _chat_history[session_id].append(AIMessage(content=answer))

def clear_history(session_id: str):
    if session_id in _chat_history:
        _chat_history[session_id].clear()

def build_agent(df, verbose: bool = True):
    agent = create_pandas_dataframe_agent(
        llm=build_llm(),
        df=df,
        agent_type="tool-calling",
        verbose=verbose,
        allow_dangerous_code=True,
        number_of_head_rows=10,
        include_df_in_prompt=True,
        max_iterations=20,
        prefix=build_system_prompt(),
    )
    return agent

def _build_input(question: str, session_id: str, max_turns: int) -> str:
    history = get_history(session_id, max_turns)
    if not history:
        return question
    history_text = "\n".join([
        f"{'User' if isinstance(m, HumanMessage) else 'Assistant'}: {m.content}"
        for m in history
    ])
    return f"Conversation so far:\n{history_text}\n\nCurrent question: {question}"

def ask(agent, question: str, session_id: str = "default", max_turns: int = 10) -> str:
    full_input = _build_input(question, session_id, max_turns)
    result = agent.invoke({"input": full_input})
    answer = result.get("output", str(result))
    save_turn(session_id, question, answer, max_turns)
    return answer



def print_summary(df) -> None:
    dfs = df if isinstance(df, list) else [df]
    for i, d in enumerate(dfs, 1):
        if len(dfs) > 1:
            print(f"\n-- Sheet {i} --")
        print(f"  Shape   : {d.shape[0]:,} rows x {d.shape[1]} columns")
        print(f"  Columns : {list(d.columns)}")
        missing = d.isnull().sum()
        if missing.any():
            print(f"  Missing : {missing[missing > 0].to_dict()}")
        print(f"  Dtypes  :\n{d.dtypes.to_string()}")

SESSION_ID = "main"

EXAMPLES = [
    "How many rows and columns does this dataset have?",
    "Show summary statistics for all numeric columns.",
    "Which column has the most missing values?",
    "Show the top 5 rows.",
    "Are there any duplicate rows?",
    "Show correlation between numeric columns.",
    "What is the value count of the first categorical column?",
]

def run_repl(agent, max_turns: int) -> None:
    print("\n" + "=" * 55)
    print("  Agent ready  —  memory ON  |  'history' 'clear' 'exit'")
    print("=" * 55)
    for q in EXAMPLES:
        print(f"  * {q}")
    print()

    while True:
        try:
            question = input("You: ").strip()
        except (KeyboardInterrupt, EOFError):
            print("\nGoodbye!")
            break

        if not question:
            continue
        if question.lower() in {"exit", "quit", "q"}:
            print("Goodbye!")
            break
        if question.lower() == "history":
            msgs = get_history(SESSION_ID, max_turns)
            if not msgs:
                print("[Memory is empty]\n")
            else:
                print("\n-- Conversation History --")
                for m in msgs:
                    role = "You  " if isinstance(m, HumanMessage) else "Agent"
                    print(f"  {role}: {m.content}")
                print()
            continue
        if question.lower() == "clear":
            clear_history(SESSION_ID)
            print("[Memory cleared]\n")
            continue

        try:
            answer = ask(agent, question, session_id=SESSION_ID, max_turns=max_turns)
            print(f"\nAgent: {answer}\n")
        except Exception as exc:
            print(f"[ERROR] {exc}\n")

def main() -> None:
    parser = argparse.ArgumentParser(description="CSV/Excel Agent — Azure GPT-4o Mini")
    parser.add_argument("--file",        type=str)
    parser.add_argument("--sheet",       type=str, default=None)
    parser.add_argument("--quiet",       action="store_true")
    parser.add_argument("--memory-size", type=int, default=10)
    args = parser.parse_args()

    file_path = args.file or input("Enter path to CSV or Excel file: ").strip()

    try:
        df = load_file(file_path, sheet_name=args.sheet)
    except (FileNotFoundError, ValueError) as exc:
        sys.exit(f"[ERROR] {exc}")

    print("\n" + "=" * 55)
    print("DATASET OVERVIEW")
    print("=" * 55)
    print_summary(df)
    print("=" * 55)

    print(f"\n[INFO] Initialising agent  (memory: last {args.memory_size} turns)...")
    agent = build_agent(df, verbose=not args.quiet)
    run_repl(agent, args.memory_size)

if __name__ == "__main__":
    main()
