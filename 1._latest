def azure_env_ok() -> bool:
    return all([
        os.getenv("AZURE_OPENAI_ENDPOINT"),
        os.getenv("AZURE_OPENAI_KEY"),
        os.getenv("AZURE_OPENAI_DEPLOYMENT"),
        os.getenv("AZURE_OPENAI_API_VERSION"),
    ])

# ─────────────────────────────────────────────
# CACHED FILTER-OPTION EXTRACTOR
# Hashing on the df id avoids re-running on every widget interaction.
# ─────────────────────────────────────────────
@st.cache_data(show_spinner=False)
def get_filter_options(df: pd.DataFrame):
    """Extract all dropdown option lists from master_df once and cache."""
    scenarios = sorted(df["Scenario"].astype(str).dropna().unique().tolist()) if "Scenario" in df.columns else []
    markets   = sorted(df["Market"].astype(str).dropna().unique().tolist())   if "Market"   in df.columns else []
    regions   = sorted(df["Region"].astype(str).dropna().unique().tolist())   if "Region"   in df.columns else []
    divisions = sorted(df["Division_Desc"].astype(str).dropna().unique().tolist()) if "Division_Desc" in df.columns else []
    if "Entity_desc" in df.columns:
        entities = sorted(df["Entity_desc"].astype(str).dropna().unique().tolist())
    elif "Entity" in df.columns:
        entities = sorted(df["Entity"].astype(str).dropna().unique().tolist())
    else:
        entities = []
    lc_oh     = sorted(df["OH/LC"].astype(str).dropna().unique().tolist()) if "OH/LC" in df.columns else []
    month_cols = get_month_cols(df)
    return scenarios, markets, regions, divisions, entities, lc_oh, month_cols

