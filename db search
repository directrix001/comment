class CheckableComboBox(QComboBox):
    """
    Multi-select combo box with checkboxes (PyQt6).
    - Keeps popup open during multi selection
    - Can refresh items while keeping checked selections
    """
    class Delegate(QStyledItemDelegate):
        def sizeHint(self, option, index):
            size = super().sizeHint(option, index)
            size.setHeight(22)
            return size
 
    def __init__(self, placeholder="Select...", *args, **kwargs):
        super().__init__(*args, **kwargs)
 
        self.setEditable(True)
        self.lineEdit().setReadOnly(True)
        self.lineEdit().setPlaceholderText(placeholder)
 
        self.setItemDelegate(CheckableComboBox.Delegate())
 
        # Keep popup open while selecting
        self.view().pressed.connect(self._handle_item_pressed)
 
        # Update displayed text when checks change
        self.model().dataChanged.connect(self._update_text)
 
    def addItem(self, text: str):
        item = QStandardItem(str(text))
        item.setFlags(Qt.ItemFlag.ItemIsEnabled | Qt.ItemFlag.ItemIsUserCheckable)
        item.setData(Qt.CheckState.Unchecked, Qt.ItemDataRole.CheckStateRole)
        self.model().appendRow(item)
 
    def addItems(self, texts):
        for t in texts:
            self.addItem(t)
 
    def checkedItems(self):
        selected = []
        for i in range(self.model().rowCount()):
            it = self.model().item(i)
            if it.checkState() == Qt.CheckState.Checked:
                selected.append(it.text())
        return selected
 
    def clearChecks(self):
        with QSignalBlocker(self.model()):
            for i in range(self.model().rowCount()):
                self.model().item(i).setCheckState(Qt.CheckState.Unchecked)
        self._update_text()
 
    def _update_text(self):
        selected = self.checkedItems()
        self.lineEdit().setText(", ".join(selected))
 
    def _handle_item_pressed(self, index):
        item = self.model().itemFromIndex(index)
        if item.checkState() == Qt.CheckState.Checked:
            item.setCheckState(Qt.CheckState.Unchecked)
        else:
            item.setCheckState(Qt.CheckState.Checked)
 
        # Keep popup open for multi-select
        self.showPopup()
 
    def setItemsKeepChecks(self, values):
        """
        Refresh items while preserving checked selections where possible.
        """
        values = [str(v) for v in values if str(v).strip() != ""]
        values = sorted(set(values))
 
        currently_checked = set(self.checkedItems())
 
        with QSignalBlocker(self.model()):
            self.model().clear()
            for v in values:
                item = QStandardItem(v)
                item.setFlags(Qt.ItemFlag.ItemIsEnabled | Qt.ItemFlag.ItemIsUserCheckable)
                item.setData(
                    Qt.CheckState.Checked if v in currently_checked else Qt.CheckState.Unchecked,
                    Qt.ItemDataRole.CheckStateRole
                )
                self.model().appendRow(item)
 
        self._update_text()
 
 
