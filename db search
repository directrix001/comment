    def loadDefaults(self):
        config = ConfigParser()
        config.read("config.ini")
 
        if "settings" not in config:
            config.add_section("settings")
            config["settings"] = {"windowWidth": "1100", "windowHeight": "700"}
 
        self.windowWidth = config["settings"].getint("windowWidth", 1100)
        self.windowHeight = config["settings"].getint("windowHeight", 700)
 
        with open("config.ini", "w") as f:
            config.write(f)
 
    def saveSettings(self):
        config = ConfigParser()
        config.read("config.ini")
 
        if "settings" not in config:
            config.add_section("settings")
 
        config["settings"] = {
            "windowWidth": str(self.windowWidth),
            "windowHeight": str(self.windowHeight),
        }
 
        with open("config.ini", "w") as f:
            config.write(f)
 
    # ---------------------- LOAD / DISPLAY ----------------------
    def load_data(self):
        try:
            if not MASTER_XLSX_PATH.exists():
                raise FileNotFoundError(
                    f"Excel file not found:\n{MASTER_XLSX_PATH}\n\n"
                    f"Expected location: ./database/Segregateddata.xlsx"
                )
 
            df = pd.read_excel(MASTER_XLSX_PATH)
 
            missing_cols = [c for c in FILTER_COLS if c not in df.columns]
            if missing_cols:
                raise ValueError(f"Missing columns: {', '.join(missing_cols)}")
 
            df[FILTER_COLS] = df[FILTER_COLS].astype(str).fillna("")
            df["Comments"] = df["Comments"].astype(str).fillna("")
 
            self.df = df
            self.current_df = df.copy()
 
            #  Default view should show ALL data
            self.display_data(self.current_df)
 
            #  Build filters with NO selections
            self.setup_filters(self.df)
 
        except Exception as e:
            QMessageBox.critical(self, "Error", f"Error loading data:\n{e}")
 
    def display_data(self, df: pd.DataFrame):
        self.current_df = df.copy()
 
        model = QStandardItemModel(df.shape[0], df.shape[1])
        model.setHorizontalHeaderLabels(df.columns)
 
        for row in range(df.shape[0]):
            for col in range(df.shape[1]):
                model.setItem(row, col, QStandardItem(str(df.iat[row, col])))
 
        self.table_view.setModel(model)
        self.table_view.resizeColumnsToContents()
 
    # ---------------------- FILTERS (MULTI) ----------------------
    def setup_filters(self, df: pd.DataFrame):
        # Clear old filters
        for i in reversed(range(self.filter_layout.count())):
            w = self.filter_layout.itemAt(i).widget()
            if w:
                w.deleteLater()
 
        self.filter_widgets = {}
        cols_per_row = 4
 
        for idx, col in enumerate(FILTER_COLS):
            cb = CheckableComboBox(placeholder=f"{col}")
 
            unique_values = sorted(set(df[col].astype(str).fillna("").tolist()))
            unique_values = [v for v in unique_values if v.strip() != ""]
 
            cb.addItems(unique_values)
            cb.setStyleSheet(self.filter_combo_stylesheet())
 
            #  No default selection = show all data
            # (We do NOT check any items here)
 
            cb.model().dataChanged.connect(self.apply_all_filters)
 
            row = idx // cols_per_row
            colpos = idx % cols_per_row
            self.filter_layout.addWidget(cb, row, colpos)
            self.filter_widgets[col] = cb
 
        for c in range(cols_per_row):
            self.filter_layout.setColumnStretch(c, 1)
 
    def refresh_filter_options_from_df(self):
        """Auto-update dropdown unique values when df changes."""
        if self.df.empty:
            return
        for col, cb in self.filter_widgets.items():
            cb.setItemsKeepChecks(self.df[col].astype(str).fillna("").tolist())
 
    def apply_all_filters(self):
        if self.df.empty:
            return
 
        filtered_df = self.df.copy()
 
        # Apply filters only if selection exists
        for col, cb in self.filter_widgets.items():
            selected = cb.checkedItems()
            if selected:
                filtered_df = filtered_df[filtered_df[col].astype(str).isin(selected)]
 
        # Apply search query
        query = self.search_bar.text().strip()
        if query:
            filtered_df = filtered_df[filtered_df["Comments"].str.contains(query, case=False, na=False)]
 
        self.display_data(filtered_df)
 
    def reset_filters(self):
        for cb in self.filter_widgets.values():
            cb.clearChecks()
            cb.setStyleSheet(self.filter_combo_stylesheet())
 
        self.search_bar.clear()
 
        #  After reset show ALL data
        self.display_data(self.df)
 
    def search_comments(self, _text=None):
        self.apply_all_filters()
 
    # ---------------------- DOWNLOAD (FILTERED VIEW) ----------------------
    def download_data(self):
        file_path, _ = QFileDialog.getSaveFileName(
            self,
            "Save Filtered Data",
            "Filtered_database",
            "CSV Files (*.csv);;Excel Files (*.xlsx)"
        )
        if not file_path:
            return
 
        try:
            df_to_save = self.current_df if not self.current_df.empty else self.df
            if file_path.endswith(".xlsx"):
                df_to_save.to_excel(file_path, index=False)
            else:
                df_to_save.to_csv(file_path, index=False)
 
            QMessageBox.information(self, "Saved", f"Data successfully saved to:\n{file_path}")
        except Exception as e:
            QMessageBox.critical(self, "Error", f"Error saving file:\n{e}")
 
