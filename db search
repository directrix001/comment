        def extract_criteria(text):
            if pd.isna(text):  # Check if the text is NaN
                return ''  # Return an empty string or any default value
            text_lower = text.lower()
            extracted = [item for item in criteria if re.search(r'\b' + re.escape(item.lower()) + r'\b', text_lower)]
            return ', '.join(extracted)

        def keyword(text):
            if pd.isna(text):  
                return ''  
            text_lower = text.lower()
            extracted = [item for item in keyword_1 if re.search(r'\b' + re.escape(item.lower()) + r'\b', text_lower)]
            return ', '.join(extracted)

 
        def extract_entity(text):
            if pd.isna(text):  
                return ''  
            text_lower = text.lower()
            extracted = [item for item in entity if re.search(r'\b' + re.escape(item.lower()) + r'\b', text_lower)]
            return ', '.join(extracted)


        extracted_df['CostCat description'] = extracted_df['Comments'].apply(extract_criteria)
        extracted_df['Function_desc'] = extracted_df['Comments'].apply(keyword)
        extracted_df['Entity_desc'] = extracted_df['Comments'].apply(extract_entity)
        extracted_df['Criteria']=extracted_df['Comments'].apply(lc_oh_1)
        extracted_df['Region']=extracted_df['Comments'].apply(extract_region_country)
        self.load_master_data(extracted_df)
 
    def load_master_data(self, df):
        model = QStandardItemModel(df.shape[0], df.shape[1])
        model.setHorizontalHeaderLabels(df.columns)
 
        for r in range(df.shape[0]):
            for c in range(df.shape[1]):
                model.setItem(r, c, QStandardItem(str(df.iat[r, c])))
 
        self.master_table_view.setModel(model)
        self.master_table_view.setEditTriggers(QAbstractItemView.EditTrigger.AllEditTriggers)
 
    def push_to_master_database(self):
        model = self.master_table_view.model()
        if model is None:
            QMessageBox.warning(self, "No Data", "No data to push.")
            return
 
        rows = model.rowCount()
        cols = model.columnCount()
 
        data = []
        for r in range(rows):
            row_data = []
            for c in range(cols):
                item = model.item(r, c)
                row_data.append("" if item is None else item.text())
            data.append(row_data)
 
        df_new = pd.DataFrame(data, columns=[model.horizontalHeaderItem(i).text() for i in range(cols)])
 
        if MASTER_XLSX_PATH.exists():
            master_df = pd.read_excel(MASTER_XLSX_PATH)
        else:
            master_df = pd.DataFrame()
 
        combined = pd.concat([master_df, df_new], ignore_index=True) if not master_df.empty else df_new
 
        if "Slide Number" in combined.columns and "Comments" in combined.columns:
            combined = combined.drop_duplicates(subset=["Slide Number", "Comments"], keep="last").reset_index(drop=True)
 
        # Ensure database folder exists
        MASTER_XLSX_PATH.parent.mkdir(parents=True, exist_ok=True)
        combined.to_excel(MASTER_XLSX_PATH, index=False)
 
        QMessageBox.information(self, "Saved", f"Data successfully pushed to:\n{MASTER_XLSX_PATH}")
 
        # Reload + refresh filters
        self.load_data()
        self.refresh_filter_options_from_df()
 
    def save_changes(self):
        file_path, _ = QFileDialog.getSaveFileName(
            self,
            "Save File",
            "Commentry_edited",
            "Excel Files (*.xlsx);;All Files (*)"
        )
        if not file_path:
            return
 
        model = self.master_table_view.model()
        if model is None:
            QMessageBox.warning(self, "No Data", "No data to save.")
            return
 
        rows = model.rowCount()
        cols = model.columnCount()
 
        data = []
        for r in range(rows):
            row_data = []
            for c in range(cols):
                item = model.item(r, c)
                row_data.append("" if item is None else item.text())
            data.append(row_data)
 
        df = pd.DataFrame(data, columns=[model.horizontalHeaderItem(i).text() for i in range(cols)])
        df.to_excel(file_path, index=False)
        QMessageBox.information(self, "Saved", f"Data saved to:\n{file_path}")
 
 
