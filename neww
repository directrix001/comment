# ─────────────────────────── copy helpers ────────────────────────────────────

def copy_excel_file(source_path: str, dest_folder: str) -> str | None:
    """Copy source_path into dest_folder, auto-incrementing the name on collision."""
    try:
        if not os.path.isfile(source_path):
            raise FileNotFoundError(f"Source file not found: {source_path}")
        os.makedirs(dest_folder, exist_ok=True)
        base_name, ext = os.path.splitext(os.path.basename(source_path))
        dest = os.path.join(dest_folder, os.path.basename(source_path))
        counter = 1
        while os.path.exists(dest):
            dest = os.path.join(dest_folder, f"{base_name}_{counter}{ext}")
            counter += 1
        shutil.copy2(source_path, dest)
        logger.info(f"Copied {source_path} → {dest}")
        return dest
    except Exception as e:
        logger.error(f"copy_excel_file error: {e}")
        return None


def copy_master_sheet(src_path: str, dest_path: str, password: str):
    """
    Read the 'Master' sheet from src_path and append it to dest_path.
    Silently skips if src_path is None or missing.
    """
    if not src_path or not os.path.isfile(src_path):
        log_step("[SKIP] copy_master_sheet: OSP Calc Tool not available – skipping Master copy.", "info")
        return
    try:
        df = pd.read_excel(src_path, sheet_name='Master', engine='openpyxl')
        wb = openpyxl.load_workbook(dest_path, keep_links=True)

        from openpyxl.workbook.protection import WorkbookProtection
        wb.security = WorkbookProtection(workbookPassword=password, lockStructure=True)

        if 'Master' in wb.sheetnames:
            del wb['Master']

        ws = wb.create_sheet(title='Master')
        for c_idx, col_name in enumerate(df.columns, start=1):
            ws.cell(row=1, column=c_idx, value=col_name)
        for r_idx, row in df.iterrows():
            for c_idx, value in enumerate(row, start=1):
                ws.cell(row=r_idx + 2, column=c_idx, value=value)
        wb.save(dest_path)
        logger.info("Master sheet copied successfully.")
    except KeyError:
        log_step("[SKIP] copy_master_sheet: 'Master' sheet not found in OSP Calc Tool – skipping.", "info")
    except Exception as e:
        logger.error(f"copy_master_sheet error: {e}")
        log_step(f"[WARN] copy_master_sheet failed ({e}) – continuing without Master sheet.", "info")
        # Do NOT re-raise – we want the run to continue


# ─────────────────────────── encrypted-xlsx reader ───────────────────────────

def read_xlsx_openpyxl(path: str, sheet_name=None, password: str | None = None,
                       return_all_sheets: bool = False):
    """
    Read an xlsx/xlsm file, decrypting it first if it is password-protected.
    Returns a DataFrame (or dict of DataFrames when return_all_sheets=True).
    """
    if not os.path.isfile(path):
        raise FileNotFoundError(f"Excel file not found: {path}")
    ext = os.path.splitext(path)[1].lower()
    if ext not in ('.xlsx', '.xlsm'):
        raise ValueError(f"Unsupported format: {ext}")
    if isinstance(sheet_name, str):
        sheet_name = sheet_name.replace("&amp;", "&")

    with open(path, "rb") as f:
        office_file = msoffcrypto.OfficeFile(f)
        encrypted = getattr(office_file, "is_encrypted", False)
        if encrypted:
            if not password:
                raise ValueError("Workbook is encrypted – provide a password.")
            buf = io.BytesIO()
            office_file.load_key(password=password)
            office_file.decrypt(buf)
            buf.seek(0)
            return pd.read_excel(buf, sheet_name=None if return_all_sheets else sheet_name,
                                 engine='openpyxl')
        return pd.read_excel(path, sheet_name=None if return_all_sheets else sheet_name,
                             engine='openpyxl')


