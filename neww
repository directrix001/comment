    _stop_event.set()

    elapsed = time.time() - start_time
    mins, secs = divmod(int(elapsed), 60)
    fmt_time = f"{mins:02d}:{secs:02d}"

    if not var_failure:
        logger.info(f"Calculation completed in {elapsed:.1f}s")
        log_step("Calculation completed successfully.", 'success')
        save_message_label.config(
            text=f"Done! Files saved to output folder. Time: {fmt_time} (mm:ss).",
            fg="green"
        )
    toggle_buttons(True)


def _fatal(msg: str):
    """Show error in label and log, stop progress, re-enable buttons."""
    log_step(msg, 'error')
    save_message_label.config(text=msg, fg="red")
    progress_bar.stop()
    toggle_buttons(True)


# ─────────────────────────── elapsed time ticker ─────────────────────────────

def update_elapsed_time():
    start = time.time()
    while not _stop_event.is_set():
        secs = int(time.time() - start)
        m, s = divmod(secs, 60)
        elapsed_time_label.config(text=f"Elapsed Time: {m:02d}:{s:02d}")
        time.sleep(0.5)


# ─────────────────────────── load converter data on month select ──────────────

def load_converter_data(_event=None):
    try:
        file_path = os.path.join(base_dir, 'Mandatory_folder', 'currency_converter.xlsx')
        _clear_numeric_entries()
        df = pd.read_excel(file_path)
        month_index = month_dropdown.current() + 1
        val = df.iloc[0, month_index]
        if pd.notna(val):
            converter_var_entry.insert(0, val)
            messagebox.showinfo(
                "Converter Data",
                f"Pre-loaded FX rate for {month_dropdown.get()} "
                f"({df.iloc[0, 0]}). Please verify."
            )
        else:
            messagebox.showinfo(
                "Converter Data",
                f"No FX rate stored for {month_dropdown.get()}. "
                "Please enter a value manually."
            )
    except Exception as e:
        messagebox.showerror("Error", f"Failed to load converter data: {e}")


# ─────────────────────────── UI helpers ──────────────────────────────────────

def _clear_numeric_entries():
    for w in (converter_var_entry, cafe_penalty_var, connectivity_var,
              converter_cfmi, ePWR_var, converter_bJPY, converter_mEUR):
        w.delete(0, tk.END)


def toggle_buttons(enabled: bool):
    submit_button_2.config(state=tk.NORMAL if enabled else tk.DISABLED)
    reset_button.config(state=tk.DISABLED if enabled else tk.NORMAL)


def log_step(message: str, tag: str = 'step'):
    ts = datetime.now().strftime('%H:%M:%S')
    log_text.insert(tk.END, f'[{ts}] {message}\n', tag)
    log_text.see(tk.END)


def reset_action():
    _stop_event.set()
    progress_bar.stop()
    elapsed_time_label.config(text="Elapsed Time: 00:00")
    save_message_label.config(text="Operation cancelled.", fg="orange")
    toggle_buttons(True)
    _clear_numeric_entries()


