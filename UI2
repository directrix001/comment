# ─────────────────────────── SAFE DataFrame helpers ──────────────────────────

def _empty_df() -> pd.DataFrame:
    """Return a completely empty DataFrame that will never raise KeyError / AttributeError."""
    return pd.DataFrame()


def _safe_read_excel_all_sheets(path: str, label: str) -> dict[str, pd.DataFrame]:
    """
    Try to read all sheets from *path*.
    Returns {} (empty dict) on ANY error so callers can fall back to _empty_df().
    """
    if not path or not os.path.isfile(path):
        log_step(f"[SKIP] {label}: file not found or path empty – using empty data.", "info")
        return {}
    try:
        sheets = pd.read_excel(path, sheet_name=None, engine="openpyxl")
        log_step(f"[OK] {label}: loaded {len(sheets)} sheet(s).", "info")
        return sheets
    except Exception as e:
        log_step(f"[WARN] {label}: could not read file ({e}) – using empty data.", "info")
        return {}


def _safe_sheet(sheets_dict: dict, sheet_name: str, label: str) -> pd.DataFrame:
    """
    Return the DataFrame for *sheet_name* from *sheets_dict*.
    Returns _empty_df() if the sheet is missing – never raises.
    """
    if not sheets_dict:
        return _empty_df()
    # Try exact match first, then case-insensitive, then partial
    if sheet_name in sheets_dict:
        return sheets_dict[sheet_name]
    lower_map = {k.lower(): k for k in sheets_dict}
    if sheet_name.lower() in lower_map:
        return sheets_dict[lower_map[sheet_name.lower()]]
    log_step(f"[SKIP] {label}: sheet '{sheet_name}' not found – using empty data.", "info")
    return _empty_df()


