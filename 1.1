with tab3:
    st.markdown('<p class="va-section-label">🤖 AI Root Cause Analyzer</p>', unsafe_allow_html=True)

    rca_src = st.radio(
        "📂 Data source for RCA",
        ["Use Pivot Data from Variance Analysis", "Upload my own Excel file"],
        horizontal=True,
        key="rca_src"
    )

    rca_df = None

    if rca_src == "Use Pivot Data from Variance Analysis":
        if st.session_state.leaf_df is not None and st.session_state.var_context is not None:
            ctx = st.session_state.var_context
            rca_df = st.session_state.leaf_df.copy()
            rca_df = rca_df.rename(columns={"A": ctx["scenario_a"], "B": ctx["scenario_b"]})
            rca_df["Variance"] = rca_df[ctx["scenario_a"]] - rca_df[ctx["scenario_b"]]
            st.success(f"✅ Loaded pivot data — {len(rca_df):,} rows · Period: {ctx['sel_period']}")
            with st.expander("Preview pivot data", expanded=False):
                st.dataframe(rca_df.head(30), use_container_width=True, height=220)
        else:
            st.warning("No variance analysis result found. Run the **📈 Variance Analysis** tab first, or upload your own file below.")
            rca_src = "Upload my own Excel file"

    if rca_src == "Upload my own Excel file":
        upl_rca = st.file_uploader("Upload Excel for RCA (.xlsx)", type=["xlsx","xls"], key="upl_rca")
        if upl_rca:
            rca_df = load_excel_cached(upl_rca.getvalue(), upl_rca.name)
            st.success(f"✅ Loaded — {len(rca_df):,} rows × {len(rca_df.columns)} columns")
            with st.expander("Preview data", expanded=False):
                st.dataframe(rca_df.head(30), use_container_width=True, height=220)

    if rca_df is not None:
        st.markdown('<hr class="va-divider">', unsafe_allow_html=True)
        st.markdown('<p class="va-section-label">⚙️ Configure Analysis</p>', unsafe_allow_html=True)

        rca_num_cols = rca_df.select_dtypes(include=["number"]).columns.tolist()

        _EXCLUDE_FROM_HIER = {"A", "B", "Δ (A-B)", "Δ% vs B", "Variance", "Calculated_Variance"}
        rca_cat_cols: List[str] = [
            c for c in rca_df.columns
            if c not in _EXCLUDE_FROM_HIER
            and c not in rca_num_cols
            and isinstance(c, str)
            and c.strip() != ""
        ]

        _var_ctx_groups: List[str] = []
        if st.session_state.var_context is not None:
            _var_ctx_groups = [
                c for c in st.session_state.var_context.get("group_fields", [])
                if isinstance(c, str) and c in rca_df.columns
            ]

        _rca_hier_default: List[str] = (
            _var_ctx_groups if _var_ctx_groups
            else [c for c in rca_cat_cols if c in rca_df.columns]
        )
        _seen: set = set()
        _rca_hier_default_clean: List[str] = []
        for _c in _rca_hier_default:
            if _c not in _seen:
                _seen.add(_c)
                _rca_hier_default_clean.append(_c)

        rca_all_cols: List[str] = [
            c for c in rca_df.columns
            if isinstance(c, str) and c.strip() != ""
        ]

        c1, c2 = st.columns([2, 1])
        with c1:
            # FIX: use safe_multiselect here too
            rca_hierarchy = safe_multiselect(
                "🔀 Hierarchy Flow (Left → deepest level)",
                rca_all_cols,
                _rca_hier_default_clean,
                key="rca_hierarchy"
            )
        with c2:
            has_var_col = st.checkbox(
                "Variance column already present?",
                value=("Variance" in rca_df.columns),
                key="rca_has_var"
            )

        if has_var_col:
            default_var = next((c for c in rca_num_cols if "var" in c.lower()), rca_num_cols[0] if rca_num_cols else None)
            rca_variance_col = st.selectbox(
                "Select Variance Column", rca_num_cols,
                index=rca_num_cols.index(default_var) if default_var and default_var in rca_num_cols else 0,
                key="rca_var_col"
            ) if rca_num_cols else ""
            rca_base = rca_comp = ""
        else:
            st.caption("Variance = Base − Compare")
            rc1, rc2 = st.columns(2)
            with rc1:
                rca_base = st.selectbox("Base Scenario column", rca_num_cols, key="rca_base") if rca_num_cols else ""
            with rc2:
                rca_comp = st.selectbox("Compare Scenario column", rca_num_cols, key="rca_comp") if rca_num_cols else ""
            rca_variance_col = ""

        st.markdown('<hr class="va-divider">', unsafe_allow_html=True)
        rca_run_btn = st.button("🤖  Generate AI Root Cause Analysis", key="rca_run_btn")

        if rca_run_btn:
            if not rca_hierarchy:
                st.warning("Select at least one hierarchy column.")
            else:
                with st.spinner("Running recursive drill-down and generating AI commentary…"):
                    st.session_state.rca_feedback_submitted = False
                    result = build_rca_graph(
                        df=rca_df,
                        hierarchy_cols=rca_hierarchy,
                        has_variance_col=has_var_col,
                        variance_col=rca_variance_col,
                        base_scenario=rca_base,
                        compare_scenario=rca_comp,
                    )
                    if "error" in result:
                        st.error(result["error"])
                    else:
                        st.session_state.rca_result = result
                        st.session_state.rca_hierarchy = rca_hierarchy
                        total_var_str = result["path_trace"][0].replace("Overall Total Variance: ", "") if result["path_trace"] else "–"
                        run_id = save_run_to_db(
                            filename="pivot_data" if rca_src == "Use Pivot Data from Variance Analysis" else "uploaded_file",
                            hierarchy=rca_hierarchy,
                            total_variance=total_var_str,
                            summary=result["final_summary"]
                        )
                        st.session_state.rca_run_id = run_id
                        st.success("✅ AI analysis complete!")

        if st.session_state.rca_result is not None:
            result = st.session_state.rca_result
            st.markdown('<hr class="va-divider">', unsafe_allow_html=True)

            total_var_str = result["path_trace"][0].replace("Overall Total Variance: ", "") if result["path_trace"] else "–"

            summary_raw = result["final_summary"]
            exec_summary = summary_raw
            rca_text = ""
            comm_text = ""
            if "---ROOT CAUSE ANALYSIS---" in summary_raw:
                parts = summary_raw.split("---ROOT CAUSE ANALYSIS---")
                exec_summary = parts[0].replace("Executive Summary:", "").strip()
                remainder = parts[1]
                if "---CATEGORY COMMENTARY---" in remainder:
                    rca_parts = remainder.split("---CATEGORY COMMENTARY---")
                    rca_text = rca_parts[0].strip()
                    comm_text = rca_parts[1].strip()
                else:
                    rca_text = remainder.strip()

            k1, k2, k3, k4 = st.columns(4)
            with k1:
                st.markdown(f'<div class="rca-kpi-card"><div class="rca-label">Total Variance</div><div class="rca-value">{total_var_str}</div></div>', unsafe_allow_html=True)
            with k2:
                st.markdown(f'<div class="rca-kpi-card"><div class="rca-label">Hierarchy Levels</div><div class="rca-value">{len(st.session_state.rca_hierarchy or [])}</div></div>', unsafe_allow_html=True)
            with k3:
                st.markdown(f'<div class="rca-kpi-card"><div class="rca-label">Primary Branches</div><div class="rca-value">{len(result.get("tree_data", []))}</div></div>', unsafe_allow_html=True)
            with k4:
                st.markdown(f'<div class="rca-kpi-card"><div class="rca-label">Final Leaf Nodes</div><div class="rca-value">{count_leaf_nodes(result.get("tree_data", []))}</div></div>', unsafe_allow_html=True)

            st.markdown("<br>", unsafe_allow_html=True)

            col_left, col_right = st.columns(2)
            with col_left:
                with st.expander("📋 Executive Summary", expanded=True):
                    st.info(exec_summary)
            with col_right:
                with st.expander("🌳 Recursive Drill-Down Trace", expanded=True):
                    if result["path_trace"]:
                        st.caption(result["path_trace"][0])
                    render_trace_tree(result.get("tree_data", []))

            if rca_text:
                st.markdown("<br>", unsafe_allow_html=True)
                with st.expander("🔍 Root Cause Analysis", expanded=True):
                    st.success(rca_text)

            if comm_text:
                st.markdown("<br>", unsafe_allow_html=True)
                with st.expander("💡 Category Commentary", expanded=True):
                    st.info(comm_text)

            st.markdown('<hr class="va-divider">', unsafe_allow_html=True)
            if st.session_state.rca_run_id:
                if st.session_state.rca_feedback_submitted:
                    st.success("Thank you for your feedback! ✅")
                else:
                    st.markdown("**How did the AI perform on this analysis?**")
                    cf1, cf2, _ = st.columns([1, 1, 10])
                    if cf1.button("👍", key="rca_up"):
                        update_run_feedback(st.session_state.rca_run_id, 1)
                        st.session_state.rca_feedback_submitted = True
                        st.toast("✅ Feedback recorded!")
                        st.rerun()
                    if cf2.button("👎", key="rca_down"):
                        update_run_feedback(st.session_state.rca_run_id, -1)
                        st.session_state.rca_feedback_submitted = True
                        st.toast("✅ Feedback recorded!")
                        st.rerun()

            st.markdown('<hr class="va-divider">', unsafe_allow_html=True)
            st.markdown('<p class="va-section-label">📥 Export</p>', unsafe_allow_html=True)
            try:
                ppt_file = generate_ppt_deck(
                    total_variance=total_var_str,
                    exec_summary=exec_summary,
                    rca_text=rca_text,
                    comm_text=comm_text,
                    tree_data=result.get("tree_data", [])
                )
                if ppt_file:
                    st.download_button(
                        "📥 Download AI Deck (.pptx)",
                        data=ppt_file,
                        file_name=f"Variance_RCA_{datetime.now().strftime('%Y%m%d')}.pptx",
                        mime="application/vnd.openxmlformats-officedocument.presentationml.presentation"
                    )
                else:
                    st.warning("python-pptx not installed. Install it to enable PPTX export.")
            except Exception as e:
                st.warning(f"PPTX export unavailable: {e}")
    else:
        st.info("Configure your data source above to start the AI root cause analysis.")

