def normalize_month_header(col) -> str:
    if hasattr(col, "strftime"):
        return f"{col.day}-{col.strftime('%b')}"
    s = str(col).strip()
    m = re.match(r"^0?(\d{1,2})\s*[-/ ]\s*([A-Za-z]+)$", s)
    if m:
        d = int(m.group(1))
        mon_txt = m.group(2).capitalize()
        if mon_txt in FULL_TO_ABBR:
            return f"{d}-{FULL_TO_ABBR[mon_txt]}"
        if len(mon_txt) == 3 and mon_txt.title() in ABBR_SET:
            return f"{d}-{mon_txt.title()}"
    m = re.match(r"^0?(\d{1,2})\s*[-/ ]\s*([A-Za-z]{3})$", s)
    if m:
        return f"{int(m.group(1))}-{m.group(2).title()}"
    m = re.match(r"^0?(\d{1,2})-(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)$", s, re.IGNORECASE)
    if m:
        return f"{int(m.group(1))}-{m.group(2).title()}"
    return s

def normalize_df_headers(df: pd.DataFrame) -> pd.DataFrame:
    df2 = df.copy()
    df2.columns = [normalize_month_header(c) for c in df.columns]
    return df2

def get_month_cols(df: pd.DataFrame) -> List[str]:
    return [c for c in df.columns if re.fullmatch(MONTH_HEADER_REGEX, str(c))]

def fmt_num(v):
    if v is None or (isinstance(v, float) and np.isnan(v)):
        return "–"
    try:
        v = float(v)
        if abs(v) >= 1_000_000:
            return f"{v/1_000_000:,.2f}M"
        if abs(v) >= 1_000:
            return f"{v/1_000:,.1f}K"
        return f"{v:,.0f}"
    except:
        return str(v)

def fmt_num_full(v):
    if v is None or (isinstance(v, float) and np.isnan(v)):
        return "–"
    try:
        return f"{float(v):,.2f}"
    except:
        return str(v)

def fmt_pct(v):
    if v is None or (isinstance(v, float) and np.isnan(v)):
        return "0.00%"   # FIX: return 0.00% instead of "–" when B=0
    try:
        return f"{float(v)*100:+.2f}%"
    except:
        return "0.00%"

def clean_numeric_series(s: pd.Series) -> pd.Series:
    s2 = s.astype(str).str.strip()
    s2 = s2.str.replace(r"^\((.*)\)$", r"-\1", regex=True)
    s2 = s2.str.replace(",", "", regex=False)
    return pd.to_numeric(s2, errors="coerce").fillna(0.0)

def variance_color_class(v, favorable_is_lower=True):
    try:
        f = float(v)
        if f == 0:
            return "neutral"
        if favorable_is_lower:
            return "fav" if f < 0 else "adv"
        else:
            return "fav" if f > 0 else "adv"
    except:
        return "neutral"

def safe_pct(delta, base):
    """Return percentage as float, 0.0 when base is zero — never NaN/None."""
    try:
        b = float(base)
        d = float(delta)
        return (d / b) if b != 0 else 0.0
    except:
        return 0.0

def clean_markdown_for_ppt(text: str) -> str:
    text = re.sub(r'\*\*(.*?)\*\*', r'\1', text)
    text = re.sub(r'\*(.*?)\*', r'\1', text)
    text = re.sub(r'#(.*?)\n', r'\1\n', text)
    return text.strip()

