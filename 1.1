def safe_multiselect(label: str, options: List[str], default: List[str], key: str) -> List[str]:
    """Wrapper around st.multiselect that guarantees default is a non-None list."""
    safe_opts    = list(options)    if options    is not None else []
    safe_default = list(default)    if default    is not None else []
    # Only keep defaults that are actually in options
    safe_default = [d for d in safe_default if d in safe_opts]
    if not safe_opts:
        return []
    return st.multiselect(label, safe_opts, default=safe_default, key=key)

# ─────────────────────────────────────────────
# CACHED DATA LOADERS
# ─────────────────────────────────────────────
@st.cache_data(show_spinner=False)
def load_excel_cached(file_bytes: bytes, file_name: str) -> pd.DataFrame:
    buf = io.BytesIO(file_bytes)
    df = pd.read_excel(buf, engine="openpyxl")
    return normalize_df_headers(df)

@st.cache_data(show_spinner=False)
def load_mapping_cached(path: str) -> Optional[pd.DataFrame]:
    if os.path.exists(path):
        try:
            return pd.read_excel(path, engine="openpyxl")
        except:
            return None
    return None

@st.cache_data(show_spinner=False)
def build_master_df_cached(file_bytes: bytes, file_name: str, mapping_path: str) -> pd.DataFrame:
    df = load_excel_cached(file_bytes, file_name)
    month_cols = get_month_cols(df)
    if not month_cols:
        return df
    df_month_numeric = df[month_cols].apply(pd.to_numeric, errors="coerce")
    df = df.copy()
    df["YTD"] = df_month_numeric.sum(axis=1)
    mapping_df = load_mapping_cached(mapping_path)
    if mapping_df is not None:
        req1 = {"Entity_desc", "Region", "Entity", "Market"}
        req2 = {"CostCat description", "OH/LC"}
        if req1.issubset(mapping_df.columns) and req2.issubset(mapping_df.columns):
            df = df.merge(
                mapping_df[["Entity_desc","Region","Entity","Market"]].drop_duplicates("Entity_desc"),
                on="Entity_desc", how="left"
            ).merge(
                mapping_df[["CostCat description","OH/LC"]].drop_duplicates("CostCat description"),
                on="CostCat description", how="left"
            )
    return df

@st.cache_data(show_spinner=False)
def get_filter_options_cached(file_bytes: bytes, file_name: str, mapping_path: str) -> dict:
    df = build_master_df_cached(file_bytes, file_name, mapping_path)
    def uniq(col):
        if col in df.columns:
            return sorted(df[col].astype(str).dropna().unique().tolist())
        return []
    month_cols = get_month_cols(df)
    return {
        "markets": uniq("Market"),
        "regions": uniq("Region"),
        "divisions": uniq("Division_Desc"),
        "entities": uniq("Entity_desc") or uniq("Entity"),
        "lc_oh": uniq("OH/LC"),
        "scenarios": uniq("Scenario") if "Scenario" in df.columns else [],
        "month_cols": month_cols,
        "avail_group": [k for k in PREF_GROUP_ORDER if k in df.columns],
        "all_cols": df.columns.tolist(),
        "num_rows": len(df),
        "num_cols": len(df.columns),
    }

# ─────────────────────────────────────────────
# PIVOT TABLE BUILDER (HTML)
# ─────────────────────────────────────────────
def build_pivot_html(leaf_df: pd.DataFrame, group_cols: List[str], header_a: str, header_b: str, favorable_is_lower=True) -> str:
    if leaf_df is None or leaf_df.empty:
        return "<p>No data.</p>"

    group_cols = [c for c in group_cols if c in leaf_df.columns]
    if not group_cols:
        return "<p>No valid group columns available in data.</p>"

    df_sorted = leaf_df.sort_values(group_cols).reset_index(drop=True)

    def sums(part):
        a = float(part["A"].sum())
        b = float(part["B"].sum())
        d = a - b
        p = safe_pct(d, b)   # FIX: use safe_pct — always 0.0 when b=0, never NaN
        return a, b, d, p

    def vc(v):
        return variance_color_class(v, favorable_is_lower)

    n_dim = len(group_cols)
    rows_html = []

    th_dims = "".join(f'<th class="left">{c}</th>' for c in group_cols)
    th_nums = f'<th>{header_a}</th><th>{header_b}</th><th>Δ (A−B)</th><th>Δ% vs B</th>'
    rows_html.append(f"<thead><tr>{th_dims}{th_nums}</tr></thead>")
    rows_html.append("<tbody>")

    A_t, B_t, D_t, P_t = sums(df_sorted)
    gd_dims = f'<td class="label-cell" colspan="{n_dim}"><strong>GRAND TOTAL</strong></td>'
    rows_html.append(
        f'<tr class="grand">{gd_dims}'
        f'<td class="num">{fmt_num_full(A_t)}</td>'
        f'<td class="num">{fmt_num_full(B_t)}</td>'
        f'<td class="num {vc(D_t)}">{fmt_num_full(D_t)}</td>'
        f'<td class="num {vc(P_t)}">{fmt_pct(P_t)}</td>'
        f'</tr>'
    )

    if n_dim == 1:
        col = group_cols[0]
        for val in df_sorted[col].astype(str).fillna("").unique():
            part = df_sorted[df_sorted[col].astype(str).fillna("") == val]
            a, b, d, p = sums(part)
            rows_html.append(
                f'<tr class="detail">'
                f'<td class="label-cell">{val}</td>'
                f'<td class="num">{fmt_num_full(a)}</td>'
                f'<td class="num">{fmt_num_full(b)}</td>'
                f'<td class="num {vc(d)}">{fmt_num_full(d)}</td>'
                f'<td class="num {vc(p)}">{fmt_pct(p)}</td>'
                f'</tr>'
            )
    else:
        def recurse_html(sub_df, level):
            col = group_cols[level]
            is_second_last = (level == n_dim - 2)
            css = f"lvl{min(level+1,2)}-header"

            for val in sub_df[col].astype(str).fillna("").unique():
                part = sub_df[sub_df[col].astype(str).fillna("") == val]
                indent = f"indent{min(level, 3)}"
                blank_cols_before = "".join('<td></td>' for _ in range(level))
                label_td = f'<td class="label-cell {indent}" colspan="{n_dim - level}"><strong>{val}</strong></td>'
                rows_html.append(f'<tr class="{css}">{blank_cols_before}{label_td}<td></td><td></td><td></td><td></td></tr>')

                if is_second_last:
                    last_col = group_cols[-1]
                    for lv in part[last_col].astype(str).fillna("").unique():
                        part2 = part[part[last_col].astype(str).fillna("") == lv]
                        a, b, d, p = sums(part2)
                        blanks = "".join('<td></td>' for _ in range(n_dim - 1))
                        indent2 = f"indent{min(level+1, 3)}"
                        rows_html.append(
                            f'<tr class="detail">'
                            f'{blanks}'
                            f'<td class="label-cell {indent2}">{lv}</td>'
                            f'<td class="num">{fmt_num_full(a)}</td>'
                            f'<td class="num">{fmt_num_full(b)}</td>'
                            f'<td class="num {vc(d)}">{fmt_num_full(d)}</td>'
                            f'<td class="num {vc(p)}">{fmt_pct(p)}</td>'
                            f'</tr>'
                        )
                else:
                    recurse_html(part, level + 1)

                a, b, d, p = sums(part)
                sub_blanks = "".join('<td></td>' for _ in range(level))
                sub_indent = f"indent{min(level, 3)}"
                rows_html.append(
                    f'<tr class="subtotal">'
                    f'{sub_blanks}'
                    f'<td class="label-cell {sub_indent}" colspan="{n_dim - level}"><em>{val} — Total</em></td>'
                    f'<td class="num">{fmt_num_full(a)}</td>'
                    f'<td class="num">{fmt_num_full(b)}</td>'
                    f'<td class="num {vc(d)}">{fmt_num_full(d)}</td>'
                    f'<td class="num {vc(p)}">{fmt_pct(p)}</td>'
                    f'</tr>'
                )

        recurse_html(df_sorted, 0)

    rows_html.append("</tbody>")
    table_content = "\n".join(rows_html)
    return f"""
<div class="pivot-wrap" style="overflow-x:auto; max-height:620px; overflow-y:auto;">
  <table class="pivot-table">{table_content}</table>
</div>
"""

# ─────────────────────────────────────────────
# HOTSPOT CARDS
# ─────────────────────────────────────────────
def build_hotspot_cards(leaf_df: pd.DataFrame, group_fields: List[str], favorable_is_lower: bool) -> str:
    if leaf_df is None or leaf_df.empty or not group_fields:
        return ""
    last_dim = group_fields[-1]
    agg = leaf_df.groupby(last_dim, dropna=False).agg(A=("A", "sum"), B=("B", "sum")).reset_index()
    agg["delta"] = agg["A"] - agg["B"]
    # FIX: use safe_pct so pct is always a float, never NaN/None
    agg["pct"] = agg.apply(lambda r: safe_pct(r["delta"], r["B"]), axis=1)
    if favorable_is_lower:
        sorted_agg = agg.sort_values("delta", ascending=False).head(4).reset_index(drop=True)
    else:
        sorted_agg = agg.sort_values("delta", ascending=True).head(4).reset_index(drop=True)
    rank_classes = ["r1", "r2", "r3", "r4"]
    rank_labels  = ["#1 Worst", "#2", "#3", "#4"]
    cards_html = ""
    for i, row in sorted_agg.iterrows():
        rc   = rank_classes[i] if i < 4 else "r4"
        rl   = rank_labels[i]  if i < 4 else f"#{i+1}"
        name = str(row[last_dim])[:30] if pd.notna(row[last_dim]) else "–"
        delta_str = fmt_num(row["delta"])
        arrow = "▲" if row["delta"] > 0 else "▼"
        pct_str = fmt_pct(row["pct"])
        a_str = fmt_num(row["A"])
        b_str = fmt_num(row["B"])
        cards_html += f"""
<div class="hs-card {rc}">
  <div class="hs-rank">{rl}</div>
  <div class="hs-dim">{last_dim}</div>
  <div class="hs-name" title="{name}">{name}</div>
  <div class="hs-delta">{arrow} {delta_str}</div>
  <div class="hs-meta">A: {a_str} &nbsp;|&nbsp; B: {b_str}</div>
  <div class="hs-meta">Δ% vs B: {pct_str}</div>
</div>"""
    return f'<div class="hs-row">{cards_html}</div>'

# ─────────────────────────────────────────────
# EXCEL EXPORT
# ─────────────────────────────────────────────
def build_excel_export(leaf_df, group_fields, header_a, header_b, sel_period,
                        sel_markets, sel_regions, sel_divisions,
                        scenario_a, scenario_b, favorable_is_lower,
                        pivot_source_long) -> bytes:
    from openpyxl import Workbook
    from openpyxl.styles import PatternFill, Font, Alignment
    from openpyxl.formatting.rule import CellIsRule
    from openpyxl.utils import get_column_letter

    wb = Workbook()
    ws_readme = wb.active
    ws_readme.title = "README"
    readme_data = [
        ("Period", sel_period),
        ("Markets", ", ".join(sel_markets) if sel_markets else "All"),
        ("Regions", ", ".join(sel_regions) if sel_regions else "All"),
        ("Scenario A", header_a),
        ("Scenario B", header_b),
        ("Favorable when", "A < B (costs)" if favorable_is_lower else "A > B (revenue)"),
        ("Division_Desc filter", ", ".join(sel_divisions) if sel_divisions else "All"),
    ]
    for r_idx, (k, v) in enumerate(readme_data, 1):
        ws_readme.cell(r_idx, 1, k).font = Font(bold=True)
        ws_readme.cell(r_idx, 2, v)
    ws_readme.column_dimensions["A"].width = 28
    ws_readme.column_dimensions["B"].width = 50

    ws_flat = wb.create_sheet("Variance (Flat)")
    flat = leaf_df.rename(columns={"A": header_a, "B": header_b})
    flat_cols = group_fields + [header_a, header_b, "Δ (A-B)", "Δ% vs B"]
    flat_out = flat[[c for c in flat_cols if c in flat.columns]]

    hdr_fill = PatternFill(start_color="0F1F3D", end_color="0F1F3D", fill_type="solid")
    hdr_font = Font(color="E8EDF8", bold=True)
    red_fill = PatternFill(start_color="FFC7CE", end_color="FFC7CE", fill_type="solid")
    green_fill = PatternFill(start_color="C6EFCE", end_color="C6EFCE", fill_type="solid")

    for ci, col in enumerate(flat_out.columns, 1):
        c = ws_flat.cell(1, ci, col)
        c.fill = hdr_fill; c.font = hdr_font; c.alignment = Alignment(horizontal="center")

    for ri, row in enumerate(flat_out.itertuples(index=False), 2):
        for ci, val in enumerate(row, 1):
            ws_flat.cell(ri, ci, val)

    nrows_flat = ws_flat.max_row
    d_col = flat_out.columns.tolist().index("Δ (A-B)") + 1 if "Δ (A-B)" in flat_out.columns else None
    p_col = flat_out.columns.tolist().index("Δ% vs B") + 1 if "Δ% vs B" in flat_out.columns else None

    def add_cf_rules(ws, cidx, nrows, fav_lower):
        cl = get_column_letter(cidx)
        rng = f"{cl}2:{cl}{nrows}"
        if fav_lower:
            ws.conditional_formatting.add(rng, CellIsRule("greaterThan", ["0"], fill=red_fill))
            ws.conditional_formatting.add(rng, CellIsRule("lessThan", ["0"], fill=green_fill))
        else:
            ws.conditional_formatting.add(rng, CellIsRule("greaterThan", ["0"], fill=green_fill))
            ws.conditional_formatting.add(rng, CellIsRule("lessThan", ["0"], fill=red_fill))

    if d_col: add_cf_rules(ws_flat, d_col, nrows_flat, favorable_is_lower)
    if p_col: add_cf_rules(ws_flat, p_col, nrows_flat, favorable_is_lower)
    for col in ws_flat.columns:
        ws_flat.column_dimensions[get_column_letter(col[0].column)].width = 18
    ws_flat.freeze_panes = "A2"

    if pivot_source_long is not None and not pivot_source_long.empty:
        ws_src = wb.create_sheet("PivotSource")
        src_cols = list(pivot_source_long.columns)
        for ci, col in enumerate(src_cols, 1):
            c = ws_src.cell(1, ci, col)
            c.fill = hdr_fill; c.font = hdr_font
        for ri, row in enumerate(pivot_source_long.itertuples(index=False), 2):
            for ci, val in enumerate(row, 1):
                ws_src.cell(ri, ci, val)
        for col in ws_src.columns:
            ws_src.column_dimensions[get_column_letter(col[0].column)].width = 18

    buf = io.BytesIO()
    wb.save(buf)
    buf.seek(0)
    return buf.read()

# ─────────────────────────────────────────────
# PPTX EXPORT
# ─────────────────────────────────────────────
def generate_ppt_deck(total_variance, exec_summary, rca_text, comm_text, tree_data) -> io.BytesIO:
    try:
        from pptx import Presentation
        from pptx.util import Inches, Pt
        from pptx.enum.text import PP_ALIGN
        from pptx.dml.color import RGBColor
    except ImportError:
        return None

    prs = Presentation()
    primary_color = RGBColor(14, 43, 92)
    accent_color  = RGBColor(0, 163, 224)
    text_color    = RGBColor(89, 89, 89)
    blank_layout  = prs.slide_layouts[6]

    def add_header(slide, title_text):
        hdr = slide.shapes.add_textbox(Inches(0.5), Inches(0.4), Inches(9), Inches(1))
        hp = hdr.text_frame.paragraphs[0]
        hp.text = title_text
        hp.font.size = Pt(28); hp.font.bold = True; hp.font.color.rgb = primary_color

    s1 = prs.slides.add_slide(blank_layout)
    tf = s1.shapes.add_textbox(Inches(1), Inches(2.5), Inches(8), Inches(2)).text_frame
    p = tf.paragraphs[0]
    p.text = "Variance Analysis & Root Cause Report"
    p.font.size = Pt(36); p.font.bold = True; p.font.color.rgb = primary_color; p.alignment = PP_ALIGN.CENTER
    p2 = tf.add_paragraph()
    p2.text = f"Total Impact: {total_variance}\nReport Date: {datetime.now().strftime('%B %d, %Y')}"
    p2.font.size = Pt(18); p2.font.color.rgb = text_color; p2.alignment = PP_ALIGN.CENTER

    s2 = prs.slides.add_slide(blank_layout)
    add_header(s2, "Executive Summary")
    cf = s2.shapes.add_textbox(Inches(0.5), Inches(1.4), Inches(9), Inches(5.5)).text_frame
    cf.word_wrap = True
    clean_s = clean_markdown_for_ppt(exec_summary)
    lines = [l.strip() for l in clean_s.split('\n') if l.strip()]
    for idx, para in enumerate(lines):
        p = cf.paragraphs[0] if idx == 0 else cf.add_paragraph()
        is_bullet = para.startswith('-') or para.startswith('*')
        clean_t = para.lstrip('-*1234567890. ')
        p.text = f"  •  {clean_t}" if is_bullet else clean_t
        p.font.size = Pt(14) if is_bullet else Pt(16)
        p.font.bold = not is_bullet
        p.font.color.rgb = text_color if is_bullet else primary_color

    s3 = prs.slides.add_slide(blank_layout)
    add_header(s3, "Recursive Drill-Down Drivers")
    df_frame = s3.shapes.add_textbox(Inches(0.5), Inches(1.4), Inches(9), Inches(5.5)).text_frame
    df_frame.word_wrap = True
    for idx, node in enumerate(tree_data):
        p = df_frame.paragraphs[0] if idx == 0 else df_frame.add_paragraph()
        p.text = f"{node['item']} (Impact: {node['value_display']})"
        p.font.bold = True; p.font.size = Pt(16); p.font.color.rgb = primary_color
        for child in node.get('children', [])[:4]:
            p_sub = df_frame.add_paragraph()
            p_sub.text = f"  •  {child['column']} - {child['item']} ({child['value_display']})"
            p_sub.font.size = Pt(14); p_sub.font.color.rgb = text_color

    if rca_text:
        s4 = prs.slides.add_slide(blank_layout)
        add_header(s4, "Root Cause Analysis")
        rf = s4.shapes.add_textbox(Inches(0.5), Inches(1.4), Inches(9), Inches(5.5)).text_frame
        rf.word_wrap = True
        p = rf.paragraphs[0]
        p.text = clean_markdown_for_ppt(rca_text)
        p.font.size = Pt(16); p.font.color.rgb = text_color

    if comm_text:
        s5 = prs.slides.add_slide(blank_layout)
        add_header(s5, "Category Commentary")
        cm = s5.shapes.add_textbox(Inches(0.5), Inches(1.4), Inches(9), Inches(5.5)).text_frame
        cm.word_wrap = True
        clean_c = clean_markdown_for_ppt(comm_text)
        comm_lines = [l.strip() for l in clean_c.split('\n') if l.strip()]
        for idx, para in enumerate(comm_lines):
            p = cm.paragraphs[0] if idx == 0 else cm.add_paragraph()
            is_b = para.startswith('-') or para.startswith('*')
            p.text = f"  •  {para.lstrip('-* ')}" if is_b else para
            p.font.size = Pt(14) if is_b else Pt(16)
            p.font.bold = not is_b
            p.font.color.rgb = text_color if is_b else primary_color

    ppt_stream = io.BytesIO()
    prs.save(ppt_stream)
    ppt_stream.seek(0)
    return ppt_stream

# ─────────────────────────────────────────────
# RCA LOGIC
# ─────────────────────────────────────────────
def build_rca_graph(df, hierarchy_cols, has_variance_col, variance_col, base_scenario, compare_scenario):
    df_work = df.copy()
    if has_variance_col:
        target_col = variance_col
        if target_col not in df_work.columns:
            return {"error": f"Column '{target_col}' not found."}
    else:
        base_col, comp_col = base_scenario, compare_scenario
        if base_col not in df_work.columns or comp_col not in df_work.columns:
            return {"error": "Scenario columns not found."}
        target_col = "Calculated_Variance"
        df_work[target_col] = pd.to_numeric(df_work[base_col], errors="coerce") - pd.to_numeric(df_work[comp_col], errors="coerce")

    def fmt_v(v):
        return f"{float(v)/1e6:,.2f}M"

    total_variance = df_work[target_col].fillna(0).sum()
    path_trace = [f"Overall Total Variance: {fmt_v(total_variance)}"]
    final_level_data = [f"Overall Total Variance: {fmt_v(total_variance)}"]

    def build_tree(current_df, depth, indent):
        if depth >= len(hierarchy_cols) or current_df.empty:
            return [], [], []
        col_name = hierarchy_cols[depth]
        is_first = depth == 0
        is_last  = depth == len(hierarchy_cols) - 1
        grouped = current_df.groupby(col_name)[target_col].sum()
        if grouped.empty or grouped.isna().all():
            return [], [], []
        top_5 = grouped.reindex(grouped.abs().sort_values(ascending=False).index).head(5)
        trace_lines, final_lines, tree_nodes = [], [], []
        for item, val in top_5.items():
            if pd.isna(item):
                continue
            item_label = str(item)
            value_label = fmt_v(float(val))
            if is_first:
                trace_lines.append(f"Primary Category: '{item_label}' (Total: {value_label})")
                final_lines.append(f"\nPrimary Category: '{item_label}' (Total Variance: {value_label})")
                title = f"Primary Category: {item_label} ({value_label})"
            elif is_last:
                trace_lines.append(f"{indent}Final Level ({col_name}): '{item_label}' -> {value_label}")
                final_lines.append(f"  - {col_name} '{item_label}': {value_label}")
                title = f"Final Level | {col_name}: {item_label} ({value_label})"
            else:
                trace_lines.append(f"{indent}Driver ({col_name}): '{item_label}' -> {value_label}")
                title = f"Driver | {col_name}: {item_label} ({value_label})"
            node = {"column": col_name, "item": item_label, "value": float(val),
                    "value_display": value_label, "title": title, "children": []}
            if not is_last:
                next_df = current_df[current_df[col_name] == item]
                sub_trace, sub_final, sub_nodes = build_tree(next_df, depth + 1, indent + "      ")
                trace_lines.extend(sub_trace)
                final_lines.extend(sub_final)
                node["children"] = sub_nodes
            tree_nodes.append(node)
        return trace_lines, final_lines, tree_nodes

    tree_trace, tree_final, tree_nodes = build_tree(df_work, 0, "")
    path_trace.extend(tree_trace)
    final_level_data.extend(tree_final)

    final_summary = ""
    try:
        from langchain_core.messages import HumanMessage, SystemMessage
        from langchain_openai import AzureChatOpenAI

        llm = AzureChatOpenAI(
            azure_endpoint=os.getenv("AZURE_OPENAI_ENDPOINT"),
            api_key=os.getenv("AZURE_OPENAI_KEY"),
            azure_deployment=os.getenv("AZURE_OPENAI_DEPLOYMENT"),
            api_version=os.getenv("AZURE_OPENAI_API_VERSION"),
        )
        system_prompt = (
            "You are a strict, professional financial data analyst. Provide an Executive Summary formatted EXACTLY as follows:\n"
            "1. A brief 1-2 sentence overall conclusion regarding the total variance.\n"
            "2. A bulleted breakdown for each 'Primary Category' analyzed.\n\n"
            "---ROOT CAUSE ANALYSIS---\n"
            "Provide a detailed 4 to 5 line analytical paragraph explaining the underlying root causes.\n\n"
            "---CATEGORY COMMENTARY---\n"
            "For each 'Primary Category', provide deep insights formatted EXACTLY as:\n"
            "[Primary Category Name]:\n"
            "- Operational Driver: ...\n- Financial Impact: ...\n- Risk/Opportunity: ...\n- Recommended Action: ...\n"
            "Do not add conversational filler."
        )
        messages = [
            SystemMessage(content=system_prompt),
            HumanMessage(content=f"Filtered Final Level Data:\n{chr(10).join(final_level_data)}")
        ]
        response = llm.invoke(messages)
        final_summary = response.content
    except Exception as e:
        final_summary = f"AI generation failed: {e}\n\nRaw drill-down data:\n" + "\n".join(final_level_data[:30])

    return {
        "path_trace": path_trace,
        "final_level_data": final_level_data,
        "tree_data": tree_nodes,
        "final_summary": final_summary,
    }

def count_leaf_nodes(nodes):
    count = 0
    for node in nodes:
        children = node.get("children", [])
        if children:
            count += count_leaf_nodes(children)
        else:
            count += 1
    return count

def render_trace_tree(nodes):
    for node in nodes:
        if node.get("children"):
            with st.expander(node["title"], expanded=False):
                render_trace_tree(node["children"])
        else:
            st.markdown(f"- **{node['title']}**")

