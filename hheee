def _int(v) -> int:
    """
    Safely convert v to int.
    Handles: int, float, str-of-digits, None, empty-string → 0 on any failure.
    This prevents TypeError when dict values are accidentally strings.
    """
    if v is None:
        return 0
    try:
        return int(v)
    except (TypeError, ValueError):
        logger.warning(f"_int(): could not convert {v!r} to int – using 0")
        return 0


def _int_list(lst) -> list:
    """Convert every element of a list/tuple to int via _int()."""
    if not lst:
        return [0]
    return [_int(x) for x in lst]


