def _join_sum(*formulas) -> str:
    parts = [x[1:] for x in formulas if x and x != Z]
    return f"={'  +  '.join(parts)}" if parts else Z


def _compound(a: str, op: str, b: str) -> str:
    if a == Z or b == Z:
        return Z
    return f"={a[1:]}{op}{b[1:]}"


# ═══════════════════════════════════════════════════════════════════════════════
#  DICT-ROW EXTRACTOR  –  always returns int
#  Use this instead of (dict.get(k) or [0])[0] everywhere.
# ═══════════════════════════════════════════════════════════════════════════════

def _row_from_dict(d: dict, key: str) -> int:
    """Extract first element of d[key] list as int; 0 on any failure."""
    try:
        val = d.get(key)
        if not val:
            return 0
        return _int(val[0] if isinstance(val, (list, tuple)) else val)
    except Exception:
        return 0


# ═══════════════════════════════════════════════════════════════════════════════
#  SAFE ROW-BLOCK BUILDER
#  Replaces every inline list-comprehension that does arithmetic on a base row.
#
#  Why a dedicated function instead of an inline comprehension?
#  ─────────────────────────────────────────────────────────────
#  The pattern   *[(excel_row+i, col, fp(base+i)) for i in range(N)]
#  has THREE independent failure modes that the inline guard cannot catch all
#  at once:
#
#    A. base == 0   → fp(0+i) = fp(i) → valid-looking row numbers (1,2,3…)
#                     that exist in the ROP-NE sheet but belong to the WRONG
#                     section → Excel writes formula pointing to wrong data.
#                     The guard `if base` catches this but ONLY when base==0.
#
#    B. HAS_ROP_NE is False but col_ROP_NE happens to be non-zero (edge case)
#       → fp() returns Z for each call, which is correct, but the tuple is
#         still added to upd_pl with value Z.  That is safe but wasteful;
#         the guard below skips the whole block cleanly.
#
#    C. col_ROP_NE == 0 (month column not found) → fp() returns Z for every
#       call → 37 Z-value entries written → harmless but clutters the output.
#       Guard below skips cleanly.
#
#    D. The cross-workbook path embedded in the formula is constructed from
#       file_path_Template which may not match the ROP-NE source.  If the
#       path is broken, Excel shows #REF regardless of the row value.
#       The guard below stops formula generation entirely when the source
#       DF or column is unavailable, preventing phantom cross-wb refs.
#
#  The function writes Z explicitly for every row when any condition fails,
#  so the caller always receives exactly `count` tuples (or 0 when skipped).
# ═══════════════════════════════════════════════════════════════════════════════

def _build_row_block(
    base_row: int,
    col_write: int,
    has_df: bool,
    col_source: int,
    fp_fn,
    zero_sentinel: str,
    start_excel_row: int,
    count: int,
) -> list:
    """
    Build a list of (excel_row, col_write, formula_or_zero) tuples.

    Parameters
    ----------
    base_row        : int   – 0-based row in the source DF where the block starts.
                              Must be > 0 for any formula to be generated.
    col_write       : int   – 1-based destination column (openpyxl).
    has_df          : bool  – HAS_* presence flag for the source DataFrame.
    col_source      : int   – column index found for this month in the source DF.
                              Must be > 0 for any formula to be generated.
    fp_fn           : callable – formula builder, e.g. fp() or fmz().
    zero_sentinel   : str   – the Z constant ("=0").
    start_excel_row : int   – first excel row to write into (1-based).
    count           : int   – number of consecutive rows to write.

    Guards
    ------
    If base_row <= 0  → all `count` cells written as zero_sentinel.
    If not has_df     → all cells written as zero_sentinel.
    If col_source <= 0 → all cells written as zero_sentinel.
    Otherwise fp_fn(base_row + i) is called; it already returns zero_sentinel
    when its own internal row/col checks fail.
    """
    base_row   = _int(base_row)
    col_write  = _int(col_write)
    col_source = _int(col_source)

    # All three conditions must be satisfied to attempt formula generation
    can_build = has_df and col_source > 0 and base_row > 0

    result = []
    for i in range(count):
        excel_row = start_excel_row + i
        if can_build:
            # fp_fn already has its own row/col guard; this is belt-and-braces
            formula = fp_fn(_int(base_row) + i)
        else:
            formula = zero_sentinel
        result.append((excel_row, col_write, formula))
    return result


