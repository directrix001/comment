    var_cfmi          = -(float(converter_cfmi.get())) / 1e6
    var_converter     = float(converter_var_entry.get())
    var_connectivity  = -(float(connectivity_var.get())) / 1e6
    var_cafe_penalty  = float(cafe_penalty_var.get())
    var_converter_bJPY = converter_bJPY.get().strip()
    var_converter_mEUR = converter_mEUR.get().strip()

    log_step(f"CFMI: {var_cfmi:.6f}  |  FX Converter: {var_converter}")

    # ── fiscal year label ────────────────────────────────────────────────────
    now = datetime.now()
    fy_start = now.year if now.month >= 4 else now.year - 1
    financial_year = f"{fy_start}-{str(fy_start+1)[-2:]}"

    # ── template paths ───────────────────────────────────────────────────────
    mand = os.path.join(base_dir, 'Mandatory_folder')
    if selected_month == 4:
        file_path_template     = os.path.join(mand, 'FY25_P_L_Summary_March_template.xlsx')
        file_path_template_1   = os.path.join(mand, 'New_KPI_P&L_FY25_Actual_New_OSP_template.xlsx')
        file_path_template_man_1 = file_path_template_1
        file_path_template_man   = file_path_template
        file_path_goodwill_template = os.path.join(mand, 'Goodwill_template.xlsx')
    else:
        prev_month_name = month_dropdown['values'][month_dropdown.current() - 1]
        file_path_template_man_1 = os.path.join(mand, 'New_KPI_P&L_FY25_Actual_New_OSP_template.xlsx')
        file_path_template_man   = os.path.join(mand, 'FY25_P_L_Summary_March_template.xlsx')
        file_path_goodwill_template = os.path.join(
            base_dir, 'Goodwill_files',
            f'Goodwill_{prev_month_name}_output_FY{financial_year}.xlsx'
        )

    # ── scan input folder for required files ─────────────────────────────────
    file_keys = [
        "P&L Summary", "OSP Calc Tool", "HFM Managerial P&L", "New KPI P&L",
        "HQ items", "Goodwill", "OSP TGK", "High_Level_Variance",
        "Relief_KD", "Purchase_Price", "UP_Calc_Template_Simulation",
        "NANO_HFM", "ITP"
    ]
    keyword_map = {
        "P&L Summary":                  "P&L Summary",
        "OSP Calc Tool":                "OSP Calc Tool",
        "HFM Managerial P&L":           "HFM Managerial P&L",
        "New KPI P&L":                  "New KPI P&L",
        "HQ items":                     "HQ items",
        "Goodwill":                     "Goodwill",
        "OSP TGK":                      "OSP TGK 1C",
        "High_Level_Variance":          "High_Level_Variance",
        "Relief_KD":                    "Reliefs KD",
        "Purchase_Price":               "Purchase Price",
        "UP_Calc_Template_Simulation":  "UP_Calc_Template_Simulation",
        "NANO_HFM":                     "NANO HFM",
        "ITP":                          "ITP",
    }
    file_paths: dict[str, str | None] = {k: None for k in file_keys}

    try:
        for fname in os.listdir(folder_path):
            for key, kw in keyword_map.items():
                if kw in fname and file_paths[key] is None:
                    full = os.path.join(folder_path, fname)
                    file_paths[key] = full
                    log_step(f"{key}: {full}")
                    logger.info(f"{key} → {full}")
    except PermissionError as e:
        _fatal(f"Cannot read input folder: {e}")
        return

    # ── copy P&L Summary and inject Master sheet ──────────────────────────────
    temp_dir = os.path.join(base_dir, 'Temp_files')
    copied_path = copy_excel_file(file_paths["P&L Summary"], temp_dir)
    if not copied_path:
        _fatal("Failed to copy P&L Summary to Temp_files.")
        return
    try:
        copy_master_sheet(file_paths["OSP Calc Tool"], copied_path, "jeanluc")
    except Exception:
        return   # error already logged in copy_master_sheet

    # ── load all DataFrames ───────────────────────────────────────────────────
    try:
        pl_summary_sheets     = pd.read_excel(file_paths["P&L Summary"],                    sheet_name=None, engine='openpyxl')
        hq_items_sheets       = pd.read_excel(file_paths["HQ items"],                       sheet_name=None, engine='openpyxl')
        osp_calc_sheets       = pd.read_excel(file_paths["OSP Calc Tool"],                  sheet_name=None, engine='openpyxl')
        hfm_mgr_sheets        = pd.read_excel(file_paths["HFM Managerial P&L"],             sheet_name=None, engine='openpyxl')
        new_kpi_sheets        = pd.read_excel(file_paths["New KPI P&L"],                    sheet_name=None, engine='openpyxl')
        goodwill_sheets       = pd.read_excel(file_paths["Goodwill"],                       sheet_name=None, engine='openpyxl')
        osp_tgk_sheets        = pd.read_excel(file_paths["OSP TGK"],                        sheet_name=None, engine='openpyxl')
        high_level_var_sheets = pd.read_excel(file_paths["High_Level_Variance"],            sheet_name=None, engine='openpyxl')
        relief_kd_sheets      = pd.read_excel(file_paths["Relief_KD"],                      sheet_name=None, engine='openpyxl')
        purchase_price_sheets = pd.read_excel(file_paths["Purchase_Price"],                 sheet_name=None, engine='openpyxl')
        up_calc_sheets        = pd.read_excel(file_paths['UP_Calc_Template_Simulation'],    sheet_name=None, engine='openpyxl')
        nano_hfm_sheets       = pd.read_excel(file_paths['NANO_HFM'],                       sheet_name=None, engine='openpyxl')
        itp_sheets            = pd.read_excel(file_paths['ITP'],                            sheet_name=None, engine='openpyxl')
    except FileNotFoundError as e:
        missing = [k for k, v in file_paths.items() if v is None]
        log_step(f"Missing input files: {missing}. {e}", 'error')
        _fatal(f"Missing files: {missing}\n{e}")
        return
    except PermissionError as e:
        log_step(f"Permission error reading files: {e}", 'error')
        _fatal(f"Permission error: {e}")
        return
    except ValueError as e:
        log_step(f"Sheet not found: {e}", 'error')
        _fatal(f"Sheet error: {e}")
        return

    # ── extract individual sheets with KeyError tracking ─────────────────────
    def _sheet(df_dict, sheet, label):
        try:
            return df_dict[sheet]
        except KeyError:
            missing_sheets_info.append(f"{label}: sheet '{sheet}' not found")
            return None

    df_p_l_rop_ne   = _sheet(pl_summary_sheets,     'ROP NE (Tagetik)',   "P&L Summary")
    df_p_l_hq       = _sheet(pl_summary_sheets,     'HQ Tagetik',         "P&L Summary")
    df_mz_conso     = _sheet(pl_summary_sheets,     'MZ conso TGK',       "P&L Summary")
    df_r_and_d      = _sheet(pl_summary_sheets,     'R&D',                "P&L Summary")
    df_p_l_new_kpi  = _sheet(pl_summary_sheets,     'New KPI Actual',     "P&L Summary")
    df_p_l_relief   = _sheet(pl_summary_sheets,     'Relief',             "P&L Summary")
    df_p_l_pl       = _sheet(pl_summary_sheets,     'P&L Actual',         "P&L Summary")
    df_p_l_reclass  = _sheet(pl_summary_sheets,     'Reclass',            "P&L Summary")
    df_p_l_mccp     = _sheet(pl_summary_sheets,     'MCPP',               "P&L Summary")
    df_p_l_ocs      = _sheet(pl_summary_sheets,     'OCS details',        "P&L Summary")
    df_hq_items     = _sheet(hq_items_sheets,       'Sheet1',             "HQ items")
    df_osp          = _sheet(osp_calc_sheets,       'Master',             "OSP Calc Tool")
    df_hmf_mgr      = _sheet(hfm_mgr_sheets,        'Managerial',         "HFM Managerial P&L")
    df_new_kpi_cfmi = _sheet(new_kpi_sheets,        'CFMI',               "New KPI P&L")
    df_act          = _sheet(new_kpi_sheets,        'Act',                "New KPI P&L")
    df_new_goodwill = _sheet(goodwill_sheets,       'GW Budget',          "Goodwill")
    df_1c_osp       = _sheet(osp_tgk_sheets,        'Summary',            "OSP TGK")
    df_hi_var       = _sheet(high_level_var_sheets, 'Feuil1',             "High_Level_Variance")
    df_relief_kd    = _sheet(relief_kd_sheets,      'vs 2+10',            "Relief_KD")
    df_purchase     = _sheet(purchase_price_sheets, 'Summary pivot',      "Purchase_Price")
    df_up_calc      = _sheet(up_calc_sheets,        'UP_Calculation',     "UP_Calc_Template_Simulation")
    df_nano_hfm     = _sheet(nano_hfm_sheets,       'Actual',             "NANO_HFM")
    df_itp          = _sheet(itp_sheets,            'BP25',               "ITP")

    # ── check for missing files / sheets ─────────────────────────────────────
    missing_files = [k for k, v in file_paths.items() if v is None]

    if missing_files or missing_sheets_info:
        details = ""
        if missing_files:
            details += "Missing files:\n• " + "\n• ".join(missing_files) + "\n\n"
        if missing_sheets_info:
            details += "Missing sheets:\n• " + "\n• ".join(missing_sheets_info)
        for msg in missing_files:
            log_step(f"Missing file: {msg}", 'error')
        for msg in missing_sheets_info:
            log_step(msg, 'error')
        messagebox.showwarning("Missing Files / Sheets", details.strip())
        _stop_event.set()
        progress_bar.stop()
        elapsed_time_label.config(text="Elapsed Time: 00:00")
        toggle_buttons(True)
        return

    if _stop_event.is_set():
        save_message_label.config(text="Operation cancelled.", fg="orange")
        progress_bar.stop()
        toggle_buttons(True)
        return

    # ── assign template paths for this run ───────────────────────────────────
    file_path_template   = copied_path
    file_path_template_1 = file_paths["New KPI P&L"]

    # ── call the calculation engine ───────────────────────────────────────────
    var_failure = False
    try:
        calculate_alternate_value_1(
            file_paths["P&L Summary"],
            df_p_l_rop_ne, df_p_l_hq,
            file_paths["OSP Calc Tool"], df_osp,
            file_paths["HFM Managerial P&L"], df_hmf_mgr,
            file_paths["New KPI P&L"], df_p_l_new_kpi,
            file_paths["HQ items"], df_hq_items,
            file_paths["Goodwill"],
            df_r_and_d, df_mz_conso, df_p_l_relief, df_p_l_pl,
            df_p_l_reclass, df_p_l_mccp, df_p_l_ocs,
            df_new_kpi_cfmi, df_new_goodwill, df_act,
            file_paths["OSP TGK"], df_1c_osp,
            file_paths["High_Level_Variance"], df_hi_var,
            file_paths["Relief_KD"], df_relief_kd,
            file_paths["Purchase_Price"], df_purchase,
            file_paths["UP_Calc_Template_Simulation"], df_up_calc,
            file_paths['NANO_HFM'], df_nano_hfm,
            file_paths['ITP'], df_itp,
            file_path_template, file_path_template_1,
            selected_month, var_converter, var_cfmi,
            var_ePWR, var_connectivity, var_cafe_penalty,
            file_path_template_man_1, file_path_template_man,
            file_path_goodwill_template, output_path,
            var_converter_bJPY, var_converter_mEUR,
        )
    except Exception as e:
        logger.exception("Calculation error")
        log_step(
            "Calculation failed – please check inputs and re-run.", 'error'
        )
        var_failure = True
        progress_bar.stop()
        save_message_label.config(text=f"Error: {e}", fg="red")

    # ── wrap-up ───────────────────────────────────────────────────────────────
    progress_bar.stop()
    _stop_event.set()

    elapsed = time.time() - start_time
    mins, secs = divmod(int(elapsed), 60)
    fmt_time = f"{mins:02d}:{secs:02d}"

    if not var_failure:
        logger.info(f"Calculation completed in {elapsed:.1f}s")
        log_step("Calculation completed successfully.", 'success')
        save_message_label.config(
            text=f"Done! Files saved to output folder. Time: {fmt_time} (mm:ss).",
            fg="green"
        )
    toggle_buttons(True)


def _fatal(msg: str):
    """Show error in label and log, stop progress, re-enable buttons."""
    log_step(msg, 'error')
    save_message_label.config(text=msg, fg="red")
    progress_bar.stop()
    toggle_buttons(True)


# ─────────────────────────── elapsed time ticker ─────────────────────────────

def update_elapsed_time():
    start = time.time()
    while not _stop_event.is_set():
        secs = int(time.time() - start)
        m, s = divmod(secs, 60)
        elapsed_time_label.config(text=f"Elapsed Time: {m:02d}:{s:02d}")
        time.sleep(0.5)


