    log_step("Started generating P&L and New KPI Actuals files…", tag='step')
    save_message_label.config(text="Processing… Please wait.", fg="black")


def _run_update_converter_then_calc():
    """Run converter update synchronously, then kick off the main calculation."""
    try:
        update_excel_converter()
    except Exception as e:
        logger.warning(f"Converter update failed (non-fatal): {e}")
    perform_calculation_2()


