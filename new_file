def calculate_alternate_value_1(
    # ── file paths ──────────────────────────────────────────────────────────
    file_path_P_L: str,
    # ── DataFrames ──────────────────────────────────────────────────────────
    df_P_L_ROP_NE:  pd.DataFrame,
    df_P_L_HQ:      pd.DataFrame,
    file_path_OSP:  str,
    df_OSP:         pd.DataFrame,
    file_path_HMF:  str,
    df_HMF_Managerial: pd.DataFrame,
    file_path_New_KPI: str,
    df_P_L_New_KPI: pd.DataFrame,
    file_HQ_Item:   str,
    df_hQ_items:    pd.DataFrame,
    file_goodwill:  str,
    df_r_and_d:     pd.DataFrame,
    df_MZ_conso:    pd.DataFrame,
    df_P_L_Relief:  pd.DataFrame,
    df_P_L_PL:      pd.DataFrame,
    df_P_L_Reclass: pd.DataFrame,
    df_P_L_MCCP:    pd.DataFrame,
    df_P_L_OCS:     pd.DataFrame,
    df_New_KPI_CFMI:  pd.DataFrame,
    df_New_goodwill:  pd.DataFrame,
    df_Act:           pd.DataFrame,
    file_paths_OSP_TGK:    str,
    df_1c_osp:             pd.DataFrame,
    file_paths_High_Level_Variance: str,
    df_high_variance_feuil:         pd.DataFrame,
    file_paths_Relief_KD:  str,
    df_Relief_KD:          pd.DataFrame,
    file_paths_Purchase_Price: str,
    df_Purchase_Price:         pd.DataFrame,
    file_paths_UP_Calc:    str,
    df_UP_Calc:            pd.DataFrame,
    file_paths_NANO_HFM:   str,
    df_nano_hfm:           pd.DataFrame,
    file_paths_ITP:        str,
    df_itp:                pd.DataFrame,
    # ── template / output ───────────────────────────────────────────────────
    file_path_Template:      str,
    file_path_Template_1:    str,
    month_number:            int,
    Var_Converter:           float,
    var_Cfmi:                float,
    ePWR_var:                float,
    connectivity_var:        float,
    cafe_penalty_var:        float,
    file_path_Template_man_1: str,
    file_path_Template_man:   str,
    file_path_goodwill_template: str,
    output_path:             str,
    var_converter_bJPY:      str,
    var_converter_mEUR:      str,
) -> None:
    """
    Build all cell-update tuples from the source DataFrames and write them
    into the copied template workbook via paste_values_KPI_PL.
    Then hand off to ACT for the second output file.
    """

    t0 = time.time()
    logger.info("calculate_alternate_value_1 started")

    # ── month offset (April = 0) ─────────────────────────────────────────────
    adj = (month_number - 4) % 12      # 0 for April, 1 for May, …

    # ══════════════════════════════════════════════════════════════════════════
    #  1.  COLUMN INDICES
    # ══════════════════════════════════════════════════════════════════════════

    col_ROP_NE   = find_columns_with_month_short(df_P_L_ROP_NE,  month_number)
    col_PL_PL    = find_columns_with_month_short(df_P_L_PL,      month_number)
    col_New_KPI  = find_columns_with_month_short(df_P_L_New_KPI, month_number)
    col_MZ_conso = find_columns_with_month_short(df_MZ_conso,    month_number)
    col_Reclass  = find_columns_with_month_short(df_P_L_Reclass, month_number)
    col_Relief   = 4 + adj

    col_r_and_d  = find_columns_with_month_long(df_r_and_d,   month_number)
    col_hq       = find_columns_with_month_long(df_hQ_items,  month_number)
    col_hq_tgt   = find_columns_with_month_long(df_P_L_HQ,    month_number)
    col_mccp     = find_columns_with_month_long(df_P_L_MCCP,  month_number)
    col_ocp      = find_columns_with_month_long(df_P_L_OCS,   month_number)

    # ── OSP TGK column (1-based offset from April) ───────────────────────────
    col_osp_tgk  = 1 + adj

    # ── column used in the P&L Actual sheet writes ───────────────────────────
    col_PL_write = col_PL_PL + 1      # the original code adds 1 here

    # ── New KPI column (1-indexed offset matches original: P_L_New_KPI_index+1) ─
    col_KPI_write = col_New_KPI + 1

    # ══════════════════════════════════════════════════════════════════════════
    #  2.  ROW INDICES – P&L Summary (ROP NE sheet)
    # ══════════════════════════════════════════════════════════════════════════

    row_map = find_row_numbers(df_P_L_ROP_NE)

    def _r(key: str) -> int:
        vals = row_map.get(key, [])
        return vals[0] if vals else 0

    row_nissan_retail   = _r("nissanretailvolume")
    row_infiniti_retail = _r("infinitiretailvolume")
    row_datsun_retail   = _r("datsunretailvolume")
    row_tiv             = _r("tiv")
    row_ms_nissan       = _r("marketshare-nissan")
    row_ms_infiniti     = _r("marketshare-infiniti")
    row_ms_datsun       = _r("marketshare-datsun")
    row_opening_stock   = _r("openingstock")
    row_nmuk            = _r("nmuk")
    row_nmisa           = _r("nmisa")
    row_nmgr            = _r("nmgr")
    row_purchase_vol    = _r("purchasevolume")
    row_total_in        = _r("totalin")
    row_ew_nissan       = _r("europeanwholesalevolume-nissan")
    row_ew_infiniti     = _r("europeanwholesalevolume-infiniti")
    row_ew_datsun       = _r("europeanwholesalevolume-datsun")
    row_exp_nissan      = _r("exportvolumenissan")
    row_exp_infiniti    = _r("exportvolume-infiniti")
    row_renault_trucks  = _r("renaulttrucks")
    row_daimler         = _r("daimler")
    row_renault         = _r("renault")
    row_gtr_idg         = _r("gtr[idg]")
    row_captives        = _r("captives")
    row_scope_adj       = _r("scopeadjustment")
    row_closing_stock   = _r("closingstock")

    # ── Turnover section row indices ─────────────────────────────────────────
    t2 = search_turnover_in_dataframe(df_P_L_ROP_NE)
    def _t(k): return (t2.get(k) or [0])[0]

    row_nissan_nv     = _t("nissan nv")
    row_nissan_bb     = _t("nissan bb")
    row_infiniti_nv   = _t("infiniti nv")
    row_infiniti_bb   = _t("infiniti bb")
    row_datsun_nv     = _t("datsun nv")
    row_datsun_bb     = _t("datsun bb")
    row_nissan_uc     = _t("nissan used cars")
    row_infiniti_uc   = _t("infiniti used cars")
    row_nissan_as     = _t("nissan after sales")
    row_infiniti_as   = _t("infiniti after sales")
    row_datsun_as     = _t("datsun after sales")
    row_exp_nis_t     = _t("export nissan")
    row_exp_inf_t     = _t("export infiniti")

    # ── FMI block row indices ─────────────────────────────────────────────────
    (fmi_nis_nv, trn_nis_nv, cos_nis_nv, vme_nis_nv,
     fmi_dat_nv, trn_dat_nv, cos_dat_nv, vme_dat_nv,
     fmi_inf_nv, trn_inf_nv, cos_inf_nv, vme_inf_nv,
     fmi_tot_nv, trn_tot_nv, cos_tot_nv, vme_tot_nv,
     ) = find_fmi_row_nv(df_P_L_ROP_NE)

    (fmi_nis_uc, trn_nis_uc, cos_nis_uc, vme_nis_uc,
     fmi_dat_uc, trn_dat_uc, cos_dat_uc, vme_dat_uc,
     fmi_tot_uc, trn_tot_uc, cos_tot_uc, vme_tot_uc,
     ) = find_fmi_row_uc(df_P_L_ROP_NE)

    (fmi_nis_as, trn_nis_as, cos_nis_as, vme_nis_as,
     fmi_dat_as, trn_dat_as, cos_dat_as, vme_dat_as,
     fmi_inf_as, trn_inf_as, cos_inf_as, vme_inf_as,
     fmi_tot_as, trn_tot_as, cos_tot_as, vme_tot_as,
     ) = find_fmi_row_as(df_P_L_ROP_NE)

    (fmi_nis_ex, trn_nis_ex, cos_nis_ex, vme_nis_ex,
     fmi_dat_ex, trn_dat_ex, cos_dat_ex, vme_dat_ex,
     fmi_inf_ex, trn_inf_ex, cos_inf_ex, vme_inf_ex,
     fmi_tot_ex, trn_tot_ex, cos_tot_ex, vme_tot_ex,
     ) = find_fmi_row_export(df_P_L_ROP_NE)

    # ── OMP section ───────────────────────────────────────────────────────────
    omp = search_omp_terms(df_P_L_ROP_NE)
    def _omp(k): return (omp.get(k) or [0])[0]
    row_x83_rop        = _omp("x83 sales to renault")
    row_f91r_rop       = _omp("f91r sales to renault trucks")
    row_pp_inter_rop   = _omp("production parts sales to inter-companies")
    row_cant_rop       = _omp("cantabria sales to third party")
    row_parts_ren_rop  = _omp("parts sales to renault")
    row_bat_oth_rop    = _omp("battery plant other costs")
    row_scraps_rop     = _omp("scraps sales")
    row_pensions_rop   = _omp("pensions")
    row_others_rop     = _omp("others")

    # ── Manufacturing section ─────────────────────────────────────────────────
    mfg = search_manufacturing_terms(df_P_L_ROP_NE)
    def _mfg(k): return (mfg.get(k) or [0])[0]
    row_materials      = _mfg("materials costs")
    row_bo_reduct      = _mfg("b/o cost reduction")
    row_renault_tp     = _mfg("renault tp")
    row_ic_kd          = _mfg("intercompany parts / kd")
    row_inbound_fr     = _mfg("inbound freight / insurance")
    row_inbound_duty   = _mfg("inbound duty")
    row_inhouse_dl     = _mfg("inhouse / direct labour")
    row_bat_nmuk       = _mfg("battery (nmuk)")
    row_events         = _mfg("events")
    row_oth_adj_mfg    = _mfg("other adjustments")
    row_others_mfg     = _mfg("others")
    row_core_fixed     = _mfg("core fixed")
    row_pic_nissan     = _mfg("pic (nissan)")
    row_regional_cost  = _mfg("regional cost")
    row_vend_tool      = _mfg("vendor tooling depreciation")
    row_projects       = _mfg("projects")
    row_nesas          = _mfg("nesas/nisa manufacturing")
    row_bat_fixed      = _mfg("battery fixed")
    row_inf_fixed_gd1a = _mfg("infiniti fixed cost (gd1a)")
    row_maint_dd       = _mfg("maintenance of existing models (d&d)")
    row_gd1a_shift     = _mfg("gd1a top position shift to icp")
    row_supp_claims    = _mfg("supplier claims & other")

    # ── G&A financial indices ─────────────────────────────────────────────────
    (idx_labour, idx_is, idx_dep, idx_prov, idx_overhead) = \
        find_financial_indices(df_P_L_ROP_NE)

    # ── OEM section ───────────────────────────────────────────────────────────
    (oem_trn, oem_std, oem_mgn, oem_veh,
     oem_log, oem_roy, oem_oth, oem_eop) = find_oem_terms(df_P_L_ROP_NE)

    # ── OCS section ───────────────────────────────────────────────────────────
    ocs_row = find_ocs_terms(df_P_L_ROP_NE)

    # ── R&D rows (ROP NE sheet) ───────────────────────────────────────────────
    rd_rows = search_rd_terms(df_P_L_ROP_NE)
    row_func_rd     = (rd_rows.get("functional r&d")     or [0])[0]
    row_nonfunc_rd  = (rd_rows.get("non functional r&d") or [0])[0]

    # ── R&D File rows ─────────────────────────────────────────────────────────
    rd_file = find_R_and_D_File(df_r_and_d)
    def _rdf(k): return (rd_file.get(k) or [0])[0]
    row_func_rd_rev    = _rdf("functional r&d revenue")
    row_func_rd_cost   = _rdf("functional r&d cost")
    row_nf_rd_rev      = _rdf("non functional r&d revenue")
    row_nf_rd_cost     = _rdf("non functional r&d cost")

    # ── MZ conso rows ─────────────────────────────────────────────────────────
    mz = MZ_Sheet_terms(df_MZ_conso)
    def _mz(k): return (mz.get(k) or [0])[0]
    row_mz_x83       = _mz("x83 sales to renault")
    row_mz_trucks    = _mz("sales to renault trucks")
    row_mz_pp_inter  = _mz("production parts sales to inter-companies")
    row_mz_cant      = _mz("cantabria sales to third party")
    row_mz_h4bu      = _mz("parts sales to renault (h4bu camshaft)")
    row_mz_scrap     = _mz("scrap sales")
    row_mz_bat       = _mz("battery plant to")
    row_mz_others    = _mz("others")

    # ── HQ items ─────────────────────────────────────────────────────────────
    tp_row  = find_transfer_price_adjustment(df_hQ_items)
    tp_base = tp_row[0] if tp_row else 0

    tax_row = tax_and_public(df_P_L_HQ)
    op_row  = operating_profit(df_P_L_HQ)
    tax_base = tax_row[0] if tax_row else 0
    op_base  = op_row[0]  if op_row  else 0

    # ── Reclass row ───────────────────────────────────────────────────────────
    reclass_row = G_and_A_Reliev1(df_P_L_Reclass)
    if reclass_row is None:
        reclass_row = 0

    # ── Relief rows ───────────────────────────────────────────────────────────
    rel = relief_search_terms_new(df_P_L_Relief)
    def _rel(k): return rel.get(k, 0)

    row_rel_recall       = _rel("recall service/campaigns")
    row_rel_kd_nmuk      = _rel("kd itp (nmuk)")
    row_rel_kd_nmisa     = _rel("kd itp (nmisa)")
    row_rel_kd_nmgr      = _rel("kd itp (nmgr)")
    row_rel_conn         = _rel("connectivity")
    row_rel_itp_nis      = _rel("itp cbu nissan")
    row_rel_itp_inf      = _rel("itp cbu infiniti")
    row_rel_iln_nmuk     = _rel("iln export (nmuk)")
    row_rel_iln_nmisa    = _rel("iln export (nmisa)")
    row_rel_err_mz       = _rel("error correction in mz (?)")
    row_rel_mz_imp       = _rel("mz impairment")
    row_rel_ga_imp       = _rel("g&a impairment")
    row_rel_cev          = _rel("compact ev/vt impairment")
    row_rel_bat_nmuk     = _rel("battery 40 kw itp ( nmuk )")
    row_rel_bat_nmisa    = _rel("battery 40 kw itp ( nmisa )")
    row_rel_bat_cancel   = _rel("battery cancelation")
    row_rel_err_wd5      = _rel("error correction in mz (after wd5)")
    row_rel_top_daim     = _rel("top daimler correction (after wd5)")
    row_rel_inf_fmi      = _rel("infiniti fmi correction (after wd5)")

    # ── OSP outside profit ───────────────────────────────────────────────────
    row_osp1, col_osp1 = find_outside_profit_and_month_value(df_OSP, month_number)
    row_osp2, col_osp2 = find_second_column_for_outside_profit(df_OSP, month_number)

