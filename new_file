def perform_calculation_2():
    missing_sheets_info: list[str] = []
    logger.info("perform_calculation_2 started")
    log_step("Reading input values. Started calculation…")
    start_time = time.time()

    # ── collect UI values ────────────────────────────────────────────────────
    folder_path    = file_path_entry.get().strip()
    output_path    = output_path_entry.get().strip()
    selected_month = month_dropdown.current() + 1
    fiscal_year    = determine_fiscal_year(selected_month)

