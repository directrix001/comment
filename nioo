def _df_ok(df: pd.DataFrame, name: str) -> bool:
    """Return True if df is a non-empty DataFrame; log a warning otherwise."""
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        logger.warning(f"[SKIP] DataFrame '{name}' is absent/empty – "
                       "affected cells will be zeroed / formula-skipped.")
        return False
    return True


def _file_ok(path: str, name: str) -> bool:
    """Return True if path points to an existing file; log a warning otherwise."""
    if not path or not os.path.isfile(path):
        logger.warning(f"[SKIP] File '{name}' not found ({path!r}) – "
                       "affected formulas will be placeholder '=0'.")
        return False
    return True


