_ZERO_FORMULA = "=0"   # placeholder written to cell when data is unavailable

def _safe_gen_formula(row: int, col: int, sheet: str,
                      file_path: str = "", fn: str = None) -> str:
    """
    Call generate_excel_formula only when row/col are valid and,
    if a cross-workbook file_path is given, only when that file exists.
    Returns '=0' on any skip/failure.
    """
    if row == 0 or col == 0:
        logger.debug(f"_safe_gen_formula skipped: row={row} col={col} sheet={sheet}")
        return _ZERO_FORMULA
    if fn and not _file_ok(fn, f"cross-wb ref [{sheet}]"):
        return _ZERO_FORMULA
    try:
        return generate_excel_formula(row, col, sheet, fn)
    except Exception as e:
        logger.warning(f"generate_excel_formula({row},{col},{sheet}) failed ({e})")
        return _ZERO_FORMULA


def _safe_extract_formula(file_path: str, sheet: str,
                          row: int, col: int, label: str = "") -> str:
    """extract_formula only when the template file actually exists."""
    if not _file_ok(file_path, label or f"template for extract_formula({sheet},{row},{col})"):
        return _ZERO_FORMULA
    try:
        result = extract_formula(file_path, sheet, row, col)
        return result if result else _ZERO_FORMULA
    except Exception as e:
        logger.warning(f"extract_formula({sheet},{row},{col}) failed ({e})")
        return _ZERO_FORMULA


def _safe_extract_value_formula(file_path: str, month: int) -> str:
    if not _file_ok(file_path, "file_path_P_L for extract_value_formula_latest"):
        return _ZERO_FORMULA
