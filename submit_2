    def find_columns_with_month(df, month_number):
        # Iterate over each row in the DataFrame
        for index, row in df.iterrows():
            # Iterate over each value in the row
            for column_name, value in row.items():
                # Check if the value matches 'apr'
                if str(value).lower() == 'apr':
                    # Find the column index of 'apr'
                    column_index_apr = df.columns.get_loc(column_name)
                    # Calculate the adjusted column index using the formula
                    adjusted_month_index_2 = (month_number - 4) % 12
                    column_index_P_L_Relief = column_index_apr + adjusted_month_index_2
                    return column_index_P_L_Relief

        # Return None if 'apr' is not found
        return None

    def find_columns_with_month_r_and_d(df, month_number):
