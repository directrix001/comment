    def _prepare_source(self):
        mode = self.cmb_src_mode.currentIndex()
        try:
            if mode == 0:
                self._use_generated_in_variance()
            elif mode == 1:
                path = self.lbl_master_path.text()
                if not path or not os.path.isfile(path):
                    QtWidgets.QMessageBox.warning(self, "Missing File", "Please select a Master DB file.")
                    return
                df = pd.read_excel(path, engine="openpyxl")
                self.master_df = normalize_dataframe_month_headers(df)
                self._populate_filters()
                self.btn_run_variance.setEnabled(True)
                self.btn_export_master.setEnabled(True)
            else:
                pathA = self.lbl_path_A.text()
                pathB = self.lbl_path_B.text()
                labA = self.txt_label_A.text().strip() or "Scenario_A"
                labB = self.txt_label_B.text().strip() or "Scenario_B"
                if not (os.path.isfile(pathA) and os.path.isfile(pathB)):
                    QtWidgets.QMessageBox.warning(self, "Missing Files", "Please select valid files for Scenario A and B.")
                    return
                dfa = normalize_dataframe_month_headers(pd.read_excel(pathA, engine="openpyxl"))
                dfb = normalize_dataframe_month_headers(pd.read_excel(pathB, engine="openpyxl"))
                dfa = dfa.copy(); dfa["Scenario"] = labA
                dfb = dfb.copy(); dfb["Scenario"] = labB
                common_cols = list(set(dfa.columns).intersection(set(dfb.columns)))
                self.master_df = pd.concat([dfa[common_cols], dfb[common_cols]], ignore_index=True)
                self._populate_filters()
                self.btn_run_variance.setEnabled(True)
                self.btn_export_master.setEnabled(True)

            QtWidgets.QMessageBox.information(self, "Source Ready", "Source loaded. Set filters and click 'Run Variance'.")
        except Exception as e:
            QtWidgets.QMessageBox.critical(self, "Prepare Source Error", str(e))

    def _populate_filters(self):
        if self.master_df is None:
            return
        df = self.master_df

        # Period options
        month_cols = [c for c in df.columns if re.fullmatch(MONTH_HEADER_REGEX, str(c))]
        period_cols = sorted(set(month_cols + [c for c in ["YTD","MTD"] if c in df.columns]),
                             key=lambda c: (100 if c in ("YTD","MTD") else 0, c))
        self.cmb_period.clear()
        self.cmb_period.addItems(period_cols)

        # Market / Region / Division_Desc
        markets = sorted(df.get('Market', pd.Series([], dtype=str)).astype(str).dropna().unique().tolist())
        regions = sorted(df.get('Region', pd.Series([], dtype=str)).astype(str).dropna().unique().tolist())
        divisions = sorted(df['Division_Desc'].astype(str).dropna().unique().tolist()) if 'Division_Desc' in df.columns else []

        fill_list_widget(self.list_market, markets, select_all=True)
        fill_list_widget(self.list_region, regions, select_all=True)
        fill_list_widget(self.list_division, divisions, select_all=True)

        # Scenarios
        scenarios = sorted(df.get('Scenario', pd.Series([], dtype=str)).astype(str).dropna().unique().tolist())
        self.cmb_scen_A.clear(); self.cmb_scen_B.clear()
        self.cmb_scen_A.addItems(scenarios)
        self.cmb_scen_B.addItems(scenarios)
        if len(scenarios) >= 2:
            self.cmb_scen_B.setCurrentIndex(1)

        # Grouping hierarchy (pivot row fields)
        full_pref_order = ['OH/LC', 'CostCat description', 'Division_Desc', 'Function_Desc', 'Departement_desc', 'Entity_desc']
        ordered = [k for k in full_pref_order if k in df.columns]
        default_checked = set([k for k in ['OH/LC', 'Division_Desc', 'Function_Desc'] if k in ordered])
        self.list_group.setFromList(ordered, default_checked=default_checked)

