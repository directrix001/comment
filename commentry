    def _load_mapping(self):
        if os.path.exists(MAPPING_PATH):
            try:
                self.mapping_df = pd.read_excel(MAPPING_PATH, engine="openpyxl")
                self.statusBar().showMessage(f"Loaded mapping: {MAPPING_PATH}")
            except Exception as e:
                self.mapping_df = None
                QtWidgets.QMessageBox.warning(self, "Mapping Load", f"Could not load mapping from {MAPPING_PATH}.\nError: {e}")
        else:
            self.mapping_df = None
            self.statusBar().showMessage("Mapping file not found; continuing without mapping.")

    def _on_open_monthly(self):
        path, _ = QtWidgets.QFileDialog.getOpenFileName(self, "Open Monthly Excel", "", "Excel Files (*.xlsx)")
        if path:
            self.lbl_monthly_path.setText(path)

    def _on_process_db(self):
        path = self.lbl_monthly_path.text()
        if not path or not os.path.isfile(path):
            QtWidgets.QMessageBox.warning(self, "Missing File", "Please select a valid monthly Excel file.")
            return
        try:
            raw = pd.read_excel(path, engine="openpyxl")
            df = normalize_dataframe_month_headers(raw)

            month_cols = [c for c in df.columns if re.fullmatch(MONTH_HEADER_REGEX, str(c))]
            if not month_cols:
                QtWidgets.QMessageBox.critical(self, "No Month Columns",
                                               "No month columns found like '1-Apr', '2-May', ... (after normalization).")
                return

            selected = self.cmb_fy_month.currentText()
            fy_index = int(selected.split("-")[0].strip())
            df2, month_cols, target_col = compute_mtd_ytd(df, fy_index)

            # Merge mapping
            if self.mapping_df is not None:
                df_map = self.mapping_df
                required_map_cols1 = {"Entity_desc","Region","Entity","Market"}
                required_map_cols2 = {"CostCat description","OH/LC"}
                if not required_map_cols1.issubset(df_map.columns) or not required_map_cols2.issubset(df_map.columns):
                    QtWidgets.QMessageBox.critical(
                        self, "Mapping Error",
                        "Mapping file missing required columns. Needs: Entity_desc, Region, Entity, Market, CostCat description, OH/LC"
                    )
                    return
                df_final = df2.merge(
                    df_map[["Entity_desc","Region","Entity","Market"]],
                    on="Entity_desc", how="left"
                ).merge(
                    df_map[["CostCat description","OH/LC"]],
                    on="CostCat description", how="left"
                )
            else:
                df_final = df2.copy()

            self.final_db = df_final
            self.db_model.setDataFrame(df_final.head(100))
            self.btn_save_csv.setEnabled(True)
            self.btn_save_xlsx.setEnabled(True)
            self.btn_send_to_var.setEnabled(True)
            QtWidgets.QMessageBox.information(self, "Success", "Transformation complete. Preview shows top 100 rows.")
        except Exception as e:
            QtWidgets.QMessageBox.critical(self, "Processing Error", str(e))

    def _on_save_csv(self):
        if self.final_db is None:
            return
        path, _ = QtWidgets.QFileDialog.getSaveFileName(self, "Save CSV", "final_db.csv", "CSV Files (*.csv)")
        if path:
            try:
                self.final_db.to_csv(path, index=False)
                QtWidgets.QMessageBox.information(self, "Saved", f"CSV saved to:\n{path}")
            except Exception as e:
                QtWidgets.QMessageBox.critical(self, "Save Error", str(e))

    def _on_save_excel(self):
        if self.final_db is None:
            return
        path, _ = QtWidgets.QFileDialog.getSaveFileName(self, "Save Excel", "final_db.xlsx", "Excel Files (*.xlsx)")
