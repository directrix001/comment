    # Pivot formatting helpers

    def _fmt_num(self, x):
        if pd.isna(x):
            return ""
        try:
            return f"{float(x):,.2f}"
        except Exception:
            return str(x)

    def _fmt_pct(self, x):
        if pd.isna(x):
            return ""
        try:
            return f"{float(x) * 100:,.2f}%"
        except Exception:
            return str(x)

    def _make_items_row(self, values, bold=False):
        items = []
        for v in values:
            it = QStandardItem("" if v is None else (v if isinstance(v, str) else str(v)))
            it.setEditable(False)
            if bold:
                f = it.font()
                f.setBold(True)
                it.setFont(f)
            items.append(it)
        return items


    # Pivot-like UI tree model (NO REPEATED LABELS, NO LAST-LEVEL DUP SUBTOTAL)

    def _build_pivot_tree_model(self, df_leaf: pd.DataFrame, group_cols: list, header_a: str, header_b: str):
        """
        QTreeView pivot-like:
        - Grand total at top
        - For each group level (except last), show a node row with subtotal numbers
        - Last level are leaf rows (details)
        - Parent labels do not repeat on children rows (we blank parent columns)
        """
        model = QStandardItemModel(self)
        headers = group_cols + [header_a, header_b, "Δ (A-B)", "Δ% vs B"]
        model.setHorizontalHeaderLabels(headers)

        if df_leaf is None or df_leaf.empty:
            return model

        df_sorted = df_leaf.sort_values(group_cols).reset_index(drop=True)

        # grand total
        A_tot = float(df_sorted["A"].sum())
        B_tot = float(df_sorted["B"].sum())
        D_tot = A_tot - B_tot
        P_tot = (D_tot / B_tot) if B_tot != 0 else np.nan

        root = model.invisibleRootItem()

        grand_labels = [""] * len(group_cols)
        if group_cols:
            grand_labels[0] = "GRAND TOTAL"
        grand_items = self._make_items_row(
            grand_labels + [self._fmt_num(A_tot), self._fmt_num(B_tot), self._fmt_num(D_tot), self._fmt_pct(P_tot)],
            bold=True
        )
        root.appendRow(grand_items)
        grand_node = grand_items[0]

        # If only one group col, there is no "higher level" parent; leaf = that col
        if len(group_cols) == 1:
            last_col = group_cols[0]
            for val in df_sorted[last_col].astype(str).fillna("").unique():
                part = df_sorted[df_sorted[last_col].astype(str).fillna("") == val]
                a = float(part["A"].sum()); b = float(part["B"].sum())
                d = a - b; p = (d / b) if b != 0 else np.nan
                row_labels = [val]  # only col
                leaf_items = self._make_items_row(
                    row_labels + [self._fmt_num(a), self._fmt_num(b), self._fmt_num(d), self._fmt_pct(p)],
                    bold=False
                )
                grand_node.appendRow(leaf_items)
            return model

        # Node lookup per level
        node_lookup = {}  # (level, key_tuple) -> QStandardItem

        def subtotal_for(part: pd.DataFrame):
            a = float(part["A"].sum()); b = float(part["B"].sum())
            d = a - b; p = (d / b) if b != 0 else np.nan
            return a, b, d, p

        # Create group node rows for levels 1..(n-1); last level is leaf details
        def get_or_create_group_node(parent_item: QStandardItem, level: int, key_tuple: tuple):
            """
            level: 1..(n-1)
            key_tuple: group_cols[:level] values
            """
            if (level, key_tuple) in node_lookup:
                return node_lookup[(level, key_tuple)]

            # Filter df for subtotal
            part = df_sorted.copy()
            for i, col in enumerate(group_cols[:level]):
                part = part[part[col].astype(str).fillna("") == key_tuple[i]]

            a, b, d, p = subtotal_for(part)

            # Pivot-like: only show label in THIS level column; blanks elsewhere
            labels = [""] * len(group_cols)
            labels[level - 1] = key_tuple[-1]

            items = self._make_items_row(
                labels + [self._fmt_num(a), self._fmt_num(b), self._fmt_num(d), self._fmt_pct(p)],
                bold=True
            )
            parent_item.appendRow(items)
            node_item = items[0]
            node_lookup[(level, key_tuple)] = node_item
            return node_item

        # Build hierarchy
        for _, r in df_sorted.iterrows():
            # traverse group cols except last
            parent = grand_node
            key_accum = []
            for level, col in enumerate(group_cols[:-1], start=1):
                v = "" if pd.isna(r[col]) else str(r[col])
                key_accum.append(v)
                parent = get_or_create_group_node(parent, level, tuple(key_accum))

            # leaf (last col)
            last_col = group_cols[-1]
            lv = "" if pd.isna(r[last_col]) else str(r[last_col])
            # Pivot-like: only last column filled at leaf line
            labels = [""] * len(group_cols)
            labels[-1] = lv

            a = float(r["A"]); b = float(r["B"])
            d = float(r["Δ (A-B)"]); p = r["Δ% vs B"]

            leaf_items = self._make_items_row(
                labels + [self._fmt_num(a), self._fmt_num(b), self._fmt_num(d), self._fmt_pct(p)],
                bold=False
            )
            parent.appendRow(leaf_items)

        return model

    def _set_pivot_view(self, df_leaf, group_fields, header_a, header_b):
        self.pivot_model = self._build_pivot_tree_model(df_leaf, group_fields, header_a, header_b)
