    # -------------------------
    # Pivot (Outline) rows builder for Excel
    # -------------------------
    def _build_pivot_outline_rows(self, df_leaf: pd.DataFrame, group_cols: List[str]):
        df_sorted = df_leaf.sort_values(group_cols).reset_index(drop=True)

        rows = []   # list of dicts with group cols + metrics + _type + _level
        spans = []  # list of (start_excel_row, end_excel_row, outline_level)

        def sums(part):
            a = float(part["A"].sum()); b = float(part["B"].sum())
            d = a - b; p = (d / b) if b != 0 else np.nan
            return a, b, d, p

        # Grand total row at top
        A_tot, B_tot, D_tot, P_tot = sums(df_sorted)
        grand = {c: "" for c in group_cols}
        grand[group_cols[0]] = "GRAND TOTAL"
        grand.update({"A": A_tot, "B": B_tot, "Δ (A-B)": D_tot, "Δ% vs B": P_tot, "_type": "grand", "_level": 0})
        rows.append(grand)

        # If only 1 group col, just list details (no subtotals)
        if len(group_cols) == 1:
            col = group_cols[0]
            for val in df_sorted[col].astype(str).fillna("").unique():
                part = df_sorted[df_sorted[col].astype(str).fillna("") == val]
                a, b, d, p = sums(part)
                r = {c: "" for c in group_cols}
                r[col] = val
                r.update({"A": a, "B": b, "Δ (A-B)": d, "Δ% vs B": p, "_type": "detail", "_level": 1})
                rows.append(r)
            return rows, spans

        # Recursion for group levels except last
        def recurse(sub_df: pd.DataFrame, level: int):
            """
            level: 0..len(group_cols)-2 (because last column is detail)
            """
            col = group_cols[level]
            next_is_last = (level == len(group_cols) - 2)
            for val in sub_df[col].astype(str).fillna("").unique():
                part = sub_df[sub_df[col].astype(str).fillna("") == val]

                # Group header row (bold, label only)
                hdr = {c: "" for c in group_cols}
                hdr[col] = val
                hdr.update({"A": None, "B": None, "Δ (A-B)": None, "Δ% vs B": None, "_type": "header", "_level": level + 1})
                rows.append(hdr)

                # Children start (for outline grouping)
                child_start_idx = len(rows)

                if next_is_last:
                    # Details at last col (no subtotal at last col)
                    last_col = group_cols[-1]
                    for lv in part[last_col].astype(str).fillna("").unique():
                        part2 = part[part[last_col].astype(str).fillna("") == lv]
                        a, b, d, p = sums(part2)
                        det = {c: "" for c in group_cols}
                        det[last_col] = lv
                        det.update({"A": a, "B": b, "Δ (A-B)": d, "Δ% vs B": p, "_type": "detail", "_level": level + 2})
                        rows.append(det)
                else:
                    recurse(part, level + 1)

                child_end_idx = len(rows) - 1

                # Subtotal row for this group (bold, numbers) -> "<val> Total"
                a, b, d, p = sums(part)
                tot = {c: "" for c in group_cols}
                tot[col] = f"{val} Total"
                tot.update({"A": a, "B": b, "Δ (A-B)": d, "Δ% vs B": p, "_type": "subtotal", "_level": level + 1})
                rows.append(tot)

                # Outline span groups only the child rows (not subtotal)
                # Excel row number = 2(header row) + row_index_in_rows_list (0-based)
                if child_end_idx >= child_start_idx:
                    start_excel = 2 + child_start_idx
                    end_excel = 2 + child_end_idx
                    spans.append((start_excel, end_excel, level + 1))

        recurse(df_sorted, 0)
        return rows, spans


    # NEW: Create Excel Pivot using xlwings (field-wise collapsible)

    def _create_native_pivot_xlwings(self, filepath: str, group_fields: list, scenario_a: str,scenario_b: str):
        """
        Creates a real Excel PivotTable using xlwings.
        Source sheet must exist: PivotSource
        Output sheet: Pivot (Native)

        Row fields  : group_fields
        Column field: Scenario
        Values      : Sum(Value), Difference From scenario_b, % Difference From scenario_b
        """
        if xw is None:
            raise RuntimeError("xlwings is not installed. Run: pip install xlwings")

        app = xw.App(visible=False, add_book=False)
        app.display_alerts = False
        app.screen_updating = False

        try:
            wb = app.books.open(os.path.abspath(filepath))

            ws_src = wb.sheets["PivotSource"]

            # Create/clear Pivot (Native)
            try:
                ws_pv = wb.sheets["Pivot (Native)"]
                ws_pv.clear()
            except Exception:
                ws_pv = wb.sheets.add("Pivot (Native)", after=ws_src)

            # Determine actual used range in PivotSource
            used = ws_src.used_range
            last_row = used.last_cell.row
            last_col = used.last_cell.column
            src_range = ws_src.range((1, 1), (last_row, last_col))

            # Create/replace an Excel Table (ListObject) named tblPivotSource
            lo_name = "tblPivotSource"
            for lo in ws_src.api.ListObjects:
                if lo.Name == lo_name:
                    lo.Delete()
                    break

            xlYes = 1
            ws_src.api.ListObjects.Add(1, src_range.api, None, xlYes).Name = lo_name

            # Excel pivot constants (avoid win32com dependency)
            xlDatabase = 1
            xlRowField = 1
            xlColumnField = 2
            xlSum = -4157
            xlOutlineRow = 2
            xlDifferenceFrom = 2
            xlPercentDifferenceFrom = 4

            pt_name = "ptVariance"

            # Create PivotCache + PivotTable
            pc = wb.api.PivotCaches().Create(SourceType=xlDatabase, SourceData=lo_name)
            pt = pc.CreatePivotTable(TableDestination=ws_pv.range("A3").api, TableName=pt_name)

            # Outline layout gives expand/collapse (+/-) per field level
            pt.RowAxisLayout(xlOutlineRow)

            # Row fields
            for i, f in enumerate(group_fields, start=1):
                pf = pt.PivotFields(f)
                pf.Orientation = xlRowField
                pf.Position = i

            # Column field
            pf_s = pt.PivotFields("Scenario")
            pf_s.Orientation = xlColumnField
            pf_s.Position = 1

            # Values (ONLY ONCE)
            pt.AddDataField(pt.PivotFields("Value"), "Amount", xlSum)

            # --- ADD calculated item for Variance (A-B) ---
            # This creates a new "Scenario" column called "Variance"
            try:
                formula = f"='{scenario_a}'-'{scenario_b}'"
                pf_s.CalculatedItems().Add("Variance", formula)
            except Exception:
                # If already exists or Excel blocks it, ignore
                pass

            # Refresh + formatting
            try:
                pt.RefreshTable()
            except Exception:
                pass

            ws_pv.autofit()

            wb.save()
            wb.close()

        finally:
            app.quit()

    # Export Variance report (Pivot-style sheet replaces Grouped)

    def _export_variance(self):
        if self.leaf_df is None or not hasattr(self, "_var_context"):
            QtWidgets.QMessageBox.warning(self, "Nothing to Export", "Run variance first.")
            return

        ctx = self._var_context
        sel_month = ctx['sel_period']
        sel_markets = ctx['sel_markets']
        sel_regions = ctx['sel_regions']
        sel_divisions = ctx['sel_divisions']
        header_a = ctx['header_a']
        header_b = ctx['header_b']
        group_fields = ctx['group_fields']
        favorable_is_lower = ctx['favorable_is_lower']
        scenario_b = ctx['scenario_b']

        path, _ = QtWidgets.QFileDialog.getSaveFileName(
            self, "Export Variance Report", f"variance_report_{sel_month.replace('/', '-')}.xlsx",
            "Excel Files (*.xlsx)"
        )
        if not path:
            return

        try:
            rows, spans = self._build_pivot_outline_rows(
                self.leaf_df[group_fields + ['A','B','Δ (A-B)','Δ% vs B']], group_fields
            )

            with pd.ExcelWriter(path, engine='openpyxl') as writer:
                # README
                cover = pd.DataFrame({
                    'Item': ['Period','Markets','Regions','Scenario A','Scenario B','Favorable when','Division_Desc filter'],
                    'Value': [
                        sel_month,
                        ', '.join(sel_markets) if sel_markets else 'All',
                        ', '.join(sel_regions) if sel_regions else 'All',
                        header_a, header_b,
                        'A < B (costs)' if favorable_is_lower else 'A > B (revenue)',
                        ', '.join(sel_divisions) if sel_divisions else 'All'
                    ]
                })
                cover.to_excel(writer, sheet_name='README', index=False)

                # Flat (optional)
                flat = self.leaf_df.rename(columns={'A': header_a, 'B': header_b})
                flat_cols = group_fields + [header_a, header_b, 'Δ (A-B)', 'Δ% vs B']
                flat[flat_cols].to_excel(writer, sheet_name='Variance (Flat)', index=False)

                # NEW: PivotSource (long-format) for REAL Excel Pivot
                # This does NOT change your variance logic; it uses the already computed agg table.
                if self.pivot_source_long is not None and not self.pivot_source_long.empty:
                    self.pivot_source_long.to_excel(writer, sheet_name="PivotSource", index=False)
                else:
                    # create sheet anyway so pivot step won't crash
                    pd.DataFrame(columns=group_fields + ["Scenario", "Value"]).to_excel(writer, sheet_name="PivotSource", index=False)

                # Pivot-style sheet (Outline)
                sheet = "Pivot (Outline)"
                cols = group_fields + [header_a, header_b, 'Δ (A-B)', 'Δ% vs B']
                pd.DataFrame(columns=cols).to_excel(writer, sheet_name=sheet, index=False)
                ws = writer.sheets[sheet]

                bold = Font(bold=True)
                fmt_num = '#,##0.00'
                fmt_pct = '0.00%'

                # Write rows
                row_cursor = 2
                for r in rows:
                    typ = r.get("_type")
                    lvl = int(r.get("_level", 0))

                    # group cols
                    for ci, col in enumerate(group_fields, start=1):
                        v = r.get(col, "")
                        c = ws.cell(row=row_cursor, column=ci, value=v)
                        # indent first group column slightly
                        if ci == 1 and typ in ("header", "subtotal"):
                            c.alignment = Alignment(indent=max(0, lvl - 1))
                        if typ in ("grand", "header", "subtotal"):
                            c.font = bold

                    # numeric cols
                    colA = len(group_fields) + 1
                    colB = len(group_fields) + 2
                    colD = len(group_fields) + 3
                    colP = len(group_fields) + 4

                    vA = r.get("A")
                    vB = r.get("B")
                    vD = r.get("Δ (A-B)")
                    vP = r.get("Δ% vs B")

                    cA = ws.cell(row=row_cursor, column=colA, value=vA)
                    cB = ws.cell(row=row_cursor, column=colB, value=vB)
                    cD = ws.cell(row=row_cursor, column=colD, value=vD)
                    cP = ws.cell(row=row_cursor, column=colP, value=vP)

                    # formats
                    cA.number_format = fmt_num
                    cB.number_format = fmt_num
                    cD.number_format = fmt_num
                    cP.number_format = fmt_pct

                    if typ in ("grand", "subtotal"):
                        cA.font = bold; cB.font = bold; cD.font = bold; cP.font = bold

                    row_cursor += 1

                ws.freeze_panes = "A2"

                # Conditional formatting on Δ and Δ%
                nrows = ws.max_row
                if nrows > 1:
                    red = PatternFill(start_color='FFC7CE', end_color='FFC7CE', fill_type='solid')
                    green = PatternFill(start_color='C6EFCE', end_color='C6EFCE', fill_type='solid')

                    def add_rules(cidx):
                        col_letter = get_column_letter(cidx)
                        rng = f"{col_letter}2:{col_letter}{nrows}"
                        if favorable_is_lower:
                            ws.conditional_formatting.add(rng, CellIsRule(operator='greaterThan', formula=['0'], fill=red))
                            ws.conditional_formatting.add(rng, CellIsRule(operator='lessThan', formula=['0'], fill=green))
                        else:
                            ws.conditional_formatting.add(rng, CellIsRule(operator='greaterThan', formula=['0'], fill=green))
                            ws.conditional_formatting.add(rng, CellIsRule(operator='lessThan', formula=['0'], fill=red))

                    add_rules(len(group_fields) + 3)  # Δ
                    add_rules(len(group_fields) + 4)  # Δ%

                # Outline grouping (collapse/expand)
                for start_r, end_r, outline_level in spans:
                    if end_r >= start_r:
                        ws.row_dimensions.group(start_r, end_r, outline_level=outline_level, hidden=True)
                ws.sheet_properties.outlinePr.summaryBelow = True

            # After saving with openpyxl, build REAL native pivot with xlwings (Excel required)
            try:
                if xw is not None:
                    self._create_native_pivot_xlwings(
                        path,
                   
                        group_fields=group_fields,
                        scenario_a=ctx["scenario_a"],
                        scenario_b=ctx["scenario_b"]

                    )
            except Exception as e:
                # Not fatal; user still gets outline pivot + flat
                QtWidgets.QMessageBox.warning(
                    self, "Native Pivot not created",
                    "Report saved.\n\nBut a real Excel PivotTable could not be created.\n"
                    f"Reason: {e}\n\n"
                    "Tip: Ensure Excel is installed and xlwings is installed."
                )

            QtWidgets.QMessageBox.information(self, "Exported", f"Variance report saved to:\n{path}")
        except Exception as e:
            QtWidgets.QMessageBox.critical(self, "Export Error", str(e))



