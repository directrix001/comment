FULL_TO_ABBR = {m: calendar.month_abbr[i] for i, m in enumerate(calendar.month_name) if m}
ABBR_SET = set(calendar.month_abbr[1:])  # {'Jan','Feb',...}

# FY month order Apr..Mar
MONTH_TO_FYNUM = {
    "Apr": 1, "May": 2, "Jun": 3, "Jul": 4, "Aug": 5, "Sep": 6,
    "Oct": 7, "Nov": 8, "Dec": 9, "Jan": 10, "Feb": 11, "Mar": 12
}
FY_NAMES = ["April","May","June","July","August","September","October","November","December","January","February","March"]
FY_MONTH_OPTIONS = [f"{str(i+1).zfill(2)} - {FY_NAMES[i]}" for i in range(12)]

MONTH_HEADER_REGEX = r"\d{1,2}-(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)"


def normalize_month_header(col) -> str:
    """Normalize header to canonical 'd-Mmm' (e.g., '1-Apr')."""
    if hasattr(col, "strftime"):
        return f"{col.day}-{col.strftime('%b')}"

    s = str(col).strip()

    # '01 - April' / '01-April' / '01/April' / '01 April'
    m = re.match(r"^0?(\d{1,2})\s*[-/ ]\s*([A-Za-z]+)$", s)
    if m:
        d = int(m.group(1))
        mon_txt = m.group(2).capitalize()
        if mon_txt in FULL_TO_ABBR:
            return f"{d}-{FULL_TO_ABBR[mon_txt]}"
        if len(mon_txt) == 3 and mon_txt.title() in ABBR_SET:
            return f"{d}-{mon_txt.title()}"

    # '01 - Apr' / '1-Apr' / '1/Apr' / '1 Apr'
    m = re.match(r"^0?(\d{1,2})\s*[-/ ]\s*([A-Za-z]{3})$", s)
    if m:
        d = int(m.group(1))
        mon_abbr = m.group(2).title()
        return f"{d}-{mon_abbr}"

    # Already canonical 'd-Mmm'
    m = re.match(r"^0?(\d{1,2})-(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)$", s, re.IGNORECASE)
    if m:
        d = int(m.group(1))
        mon_abbr = m.group(2).title()
        return f"{d}-{mon_abbr}"

    return s


def normalize_dataframe_month_headers(df: pd.DataFrame) -> pd.DataFrame:
    cols = [normalize_month_header(c) for c in df.columns]
    df2 = df.copy()
    df2.columns = cols
    return df2


def compute_mtd_ytd(df: pd.DataFrame, fy_index: int) -> Tuple[pd.DataFrame, List[str], str]:
    """Given df with normalized month headers, compute YTD and MTD for an FY index (1..12)."""
    month_cols = [c for c in df.columns if re.fullmatch(MONTH_HEADER_REGEX, str(c))]
    if not month_cols:
        raise ValueError("No month columns found (expected '1-Apr' format).")

    df_month_numeric = df[month_cols].apply(pd.to_numeric, errors="coerce")
    df = df.copy()
    df["YTD"] = df_month_numeric.sum(axis=1)

    num_to_col = {}
    for c in month_cols:
        try:
            _d, mon = str(c).split("-")
        except ValueError:
            continue
        mon = mon.title()
        if mon not in MONTH_TO_FYNUM:
            continue
        fy_num = MONTH_TO_FYNUM[mon]
        num_to_col[fy_num] = c

    if fy_index not in num_to_col:
        raise ValueError(
            f"Selected FY month {fy_index} not present in headers. Found FY months: {sorted(num_to_col.keys())}"
        )

    target_col = num_to_col[fy_index]
    df["MTD"] = pd.to_numeric(df[target_col], errors="coerce")
    return df, month_cols, target_col


# Qt: Pandas Table Model (DB Generator preview)

class PandasModel(QtCore.QAbstractTableModel):
    def __init__(self, df: pd.DataFrame = pd.DataFrame(), parent=None):
        super().__init__(parent)
        self._df = df

    def setDataFrame(self, df: pd.DataFrame):
        self.beginResetModel()
        self._df = df.copy()
        self.endResetModel()

    def rowCount(self, parent=None):
        return 0 if self._df is None else len(self._df.index)

    def columnCount(self, parent=None):
        return 0 if self._df is None else len(self._df.columns)

    def data(self, index, role=Qt.ItemDataRole.DisplayRole):
        if not index.isValid() or self._df is None:
            return None
        if role == Qt.ItemDataRole.DisplayRole:
            val = self._df.iat[index.row(), index.column()]
            if isinstance(val, float):
                return f"{val:,.2f}" if not np.isnan(val) else ""
            return "" if pd.isna(val) else str(val)
        return None

    def headerData(self, section, orientation, role=Qt.ItemDataRole.DisplayRole):
        if self._df is None:
            return None
        if role == Qt.ItemDataRole.DisplayRole:
            if orientation == Qt.Orientation.Horizontal:
                return str(self._df.columns[section])
            else:
                return str(self._df.index[section])
        return None


# Checkable + Reorderable List for Grouping

class CheckableReorderableList(QtWidgets.QListWidget):
    orderChanged = QtCore.pyqtSignal()

    def __init__(self, parent=None):
        super().__init__(parent)
        self.setDragDropMode(QtWidgets.QAbstractItemView.DragDropMode.InternalMove)
        self.setDefaultDropAction(Qt.DropAction.MoveAction)
        self.setSelectionMode(QtWidgets.QAbstractItemView.SelectionMode.SingleSelection)
        self.setAlternatingRowColors(True)

    def dropEvent(self, e: QtGui.QDropEvent):
        super().dropEvent(e)
        self.orderChanged.emit()

    def addOption(self, text: str, checked: bool = True):
        it = QtWidgets.QListWidgetItem(text)
        it.setFlags(
            it.flags()
            | Qt.ItemFlag.ItemIsUserCheckable
            | Qt.ItemFlag.ItemIsEnabled
            | Qt.ItemFlag.ItemIsSelectable
            | Qt.ItemFlag.ItemIsDragEnabled
        )
        it.setCheckState(Qt.CheckState.Checked if checked else Qt.CheckState.Unchecked)
        self.addItem(it)

    def setFromList(self, ordered_options: List[str], default_checked: set | None = None):
        self.clear()
        default_checked = default_checked or set()
        for opt in ordered_options:
            self.addOption(opt, checked=(opt in default_checked))

    def checkedItems(self) -> List[str]:
        return [
            self.item(i).text()
            for i in range(self.count())
            if self.item(i).checkState() == Qt.CheckState.Checked
        ]


# Utilities

def fill_list_widget(listw: QtWidgets.QListWidget, options: List[str], select_all: bool = True):
    listw.clear()
    for opt in options:
        item = QtWidgets.QListWidgetItem(opt)
        item.setFlags(item.flags() | Qt.ItemFlag.ItemIsUserCheckable | Qt.ItemFlag.ItemIsSelectable | Qt.ItemFlag.ItemIsEnabled)
        item.setCheckState(Qt.CheckState.Checked if select_all else Qt.CheckState.Unchecked)
        listw.addItem(item)

def selected_items(listw: QtWidgets.QListWidget) -> List[str]:
    vals = []
    for i in range(listw.count()):
        it = listw.item(i)
        if it.checkState() == Qt.CheckState.Checked:
            vals.append(it.text())
    return vals



