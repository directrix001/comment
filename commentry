    # Run Variance (numeric fix + pivot math)

    def _run_variance(self):
        if self.master_df is None:
            QtWidgets.QMessageBox.warning(self, "No Data", "Load a source first.")
            return

        df = self.master_df.copy()

        sel_period = self.cmb_period.currentText()
        sel_markets = selected_items(self.list_market)
        sel_regions = selected_items(self.list_region)
        sel_divisions = selected_items(self.list_division)
        scenario_a = self.cmb_scen_A.currentText()
        scenario_b = self.cmb_scen_B.currentText()
        favorable_is_lower = self.rb_costs.isChecked()

        group_fields = self.list_group.checkedItems()
        if self.chk_include_geo.isChecked():
            for geo in ['Market', 'Region']:
                if geo in df.columns and geo not in group_fields:
                    group_fields.insert(0, geo)

        if not group_fields:
            QtWidgets.QMessageBox.information(self, "Grouping Required", "Select at least one pivot row field.")
            return

        if sel_period not in df.columns:
            QtWidgets.QMessageBox.critical(self, "Missing Column", f"Selected period '{sel_period}' not in data.")
            return
        if 'Scenario' not in df.columns:
            QtWidgets.QMessageBox.critical(self, "Missing Column", "Data must contain a 'Scenario' column.")
            return

        # Clean Scenario values
        df["Scenario"] = df["Scenario"].astype(str).str.strip()

        # Filters
        if sel_markets:
            df = df[df.get('Market', '').astype(str).isin(sel_markets)]
        if sel_regions:
            df = df[df.get('Region', '').astype(str).isin(sel_regions)]
        if 'Division_Desc' in df.columns and sel_divisions:
            df = df[df['Division_Desc'].astype(str).isin(sel_divisions)]

        df = df[df['Scenario'].astype(str).isin([scenario_a, scenario_b])]

        use_cols = group_fields + ['Scenario', sel_period]
        missing = [c for c in use_cols if c not in df.columns]
        if missing:
            QtWidgets.QMessageBox.critical(self, "Missing Columns", f"Required columns missing: {missing}")
            return

        base = df[use_cols].rename(columns={sel_period: 'Value'}).copy()

        # --- CRITICAL numeric fix ---
        val = base["Value"].astype(str).str.strip()
        val = val.str.replace(r"^\((.*)\)$", r"-\1", regex=True)  # (123) -> -123
        val = val.str.replace(",", "", regex=False)              # remove commas
        base["Value"] = pd.to_numeric(val, errors="coerce").fillna(0.0)

        # Aggregate & pivot by Scenario
        agg = base.groupby(group_fields + ['Scenario'], dropna=False)['Value'].sum().reset_index()

        # NEW: Keep long-format pivot source for Native Pivot export (NO logic change)
        self.pivot_source_long = agg.copy()

        piv = agg.pivot_table(index=group_fields, columns='Scenario', values='Value', aggfunc='sum', fill_value=0.0)

        for s in [scenario_a, scenario_b]:
            if s not in piv.columns:
                piv[s] = 0.0

        piv = piv[[scenario_a, scenario_b]].rename(columns={scenario_a: 'A', scenario_b: 'B'})

        leaf_df = piv.reset_index()
        leaf_df['Δ (A-B)'] = leaf_df['A'] - leaf_df['B']
        leaf_df['Δ% vs B'] = np.where(leaf_df['B'] == 0, np.nan, leaf_df['Δ (A-B)'] / leaf_df['B'])

        self.leaf_df = leaf_df

        header_a = f"{scenario_a} (A)"
        header_b = f"{scenario_b} (B)"

        # Pivot UI preview (Excel-like label repetition behavior)
        self._set_pivot_view(self.leaf_df, group_fields, header_a, header_b)

        self.btn_export_excel.setEnabled(True)

        self._var_context = {
            'sel_period': sel_period,
            'sel_markets': sel_markets,
            'sel_regions': sel_regions,
            'sel_divisions': sel_divisions,
            'scenario_a': scenario_a,
            'scenario_b': scenario_b,
            'header_a': header_a,
            'header_b': header_b,
            'group_fields': group_fields,
            'favorable_is_lower': favorable_is_lower
        }

        QtWidgets.QMessageBox.information(self, "Variance Ready",
                                          f"Period: {sel_period} | Compare: {header_a} vs {header_b}")


