from openpyxl import load_workbook


def manage_sheet_visibility(file_name, month_number):
 
    month_abbr = {
        1: 'Jan', 2: 'Feb', 3: 'Mar', 4: 'Apr',
        5: 'May', 6: 'Jun', 7: 'Jul', 8: 'Aug',
        9: 'Sep', 10: 'Oct', 11: 'Nov', 12: 'Dec'
    }
    
    # Validate the month_number input
    if month_number not in month_abbr:
        raise ValueError("Invalid month number. Please provide a number between 1 and 12.")
    
    # Derive current and previous sheet names
    current_sheet_name = f"HFM {month_abbr[month_number]}"
    previous_month_number = month_number - 1 if month_number > 1 else 12
    previous_sheet_name = f"HFM {month_abbr[previous_month_number]}"
    
    try:
        # Load workbook
        workbook = load_workbook(filename=file_name)
        
        # Unhide the current month's sheet
        if current_sheet_name in workbook.sheetnames:
            workbook[current_sheet_name].sheet_state = 'visible'
        else:
            raise ValueError(f"Sheet '{current_sheet_name}' does not exist in the workbook.")
        
        # Hide the previous month's sheet
        if previous_sheet_name in workbook.sheetnames:
            workbook[previous_sheet_name].sheet_state = 'hidden'
        
        # Save changes to workbook
        workbook.save(filename=file_name)
        
        return f"Unhid '{current_sheet_name}' and hid '{previous_sheet_name}'."
    
    except Exception as e:
        raise RuntimeError(f"An error occurred while managing sheet visibility: {e}")



