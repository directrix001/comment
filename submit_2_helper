def find_month_columns_export(df, month_number):
    # Define the mapping of month numbers to month codes
    month_codes = {
        4: "M01",
        5: "M02",
        6: "M03",
        7: "M04",
        8: "M05",
        9: "M06",
        10: "M07",
        11: "M08",
        12: "M09",
        1: "M10",
        2: "M11",
        3: "M12"
    }
    
    # Get the corresponding month code from the month number
    month_code = month_codes.get(month_number)
    
    if not month_code:
        raise ValueError("Invalid month number provided.")
    
    # Initialize a list to store column indices
    column_indices = []
    
    # Iterate over each row in the DataFrame
    for _, row in df.iterrows():
        temp_indices = []
        
        # Iterate over each cell in the row
        for col_index, value in enumerate(row):
            # Check if the cell value matches the month code
            if isinstance(value, str) and month_code in value:
                temp_indices.append(col_index)
                
                # If occurrences are found, add them to the main list
                column_indices.extend(temp_indices)
    
    # Return sorted list of unique column indices
    return sorted(set(column_indices))

def find_op_and_month(df, month_number):

    months = ["January", "February", "March", "April", "May", "June", 
              "July", "August", "September", "October", "November", "December"]
    
    if month_number < 1 or month_number > 12:
        raise ValueError("Month number must be between 1 and 12.")
    
    month_name = months[month_number - 1].lower()

    # Initialize variables to store indices
    op_row_index = None
    month_col_index = None

    # Iterate over rows to find 'OP'
    for index, row in df.iterrows():
        if 'op' in row.astype(str).str.lower().values:
            op_row_index = index
            break

    # Find column index for the specified month
    for col_index, col_name in enumerate(df.columns):
        if month_name in col_name.lower():
            month_col_index = col_index
            break

    return op_row_index, month_col_index





