def search_turnover_in_dataframe(df):
    # Convert all text in the DataFrame to lowercase for case-insensitive searching
    df_lower = df.apply(lambda x: x.astype(str).str.lower())

    # Static variables for storing row indices
    TURNOVER_ROW_INDEX = None
    SEARCH_RANGE_START = None
    SEARCH_RANGE_END = None

    # Find the row index where 'turnover' appears in the first four columns
    for col in df_lower.columns[:4]:
        turnover_row_index = df_lower[df_lower[col].str.contains('turnover', na=False)].index
        if not turnover_row_index.empty:
            TURNOVER_ROW_INDEX = turnover_row_index[0]
            SEARCH_RANGE_START = TURNOVER_ROW_INDEX
            SEARCH_RANGE_END = TURNOVER_ROW_INDEX + 22
            break

    if TURNOVER_ROW_INDEX is None:
        print("Turnover not found in the first four columns.")
        return

    # Define search terms
    search_terms = [
        'nissan nv', 'nissan bb', 'datsun nv', 'datsun bb','infiniti nv','infiniti bb',
        'infiniti used cars', 'nissan used cars', 'nissan after sales',
        'datsun after sales', 'infiniti after sales', 'export nissan',
        'export datsun', 'export infiniti'
    ]

    # Initialize dictionary to store row indices for each term
    term_indices = {term: [] for term in search_terms}

    # Search for each term in the specified range (SEARCH_RANGE_START to SEARCH_RANGE_END)
    search_range = df_lower.iloc[SEARCH_RANGE_START:SEARCH_RANGE_END]
    for term in search_terms:
        for col in search_range.columns:
            indices = search_range[search_range[col].str.contains(term, na=False)].index.tolist()
            term_indices[term].extend(indices)
    return term_indices


def find_fmi_row_nv(df):
    # Convert the first three columns to lowercase if they are of object type
    df_lower = df.iloc[:, 0:3].apply(lambda col: col.str.lower() if col.dtype == 'object' else col)
    
    # Find start indices for each term
    start_index_nissan = df_lower[df_lower.isin(['nissan nv']).any(axis=1)].index
    start_index_datsun = df_lower[df_lower.isin(['datsun nv']).any(axis=1)].index
    start_index_infiniti = df_lower[df_lower.isin(['infiniti nv']).any(axis=1)].index
    start_index_total = df_lower[df_lower.isin(['total nv']).any(axis=1)].index
    
    # Check if all terms are found
    if start_index_nissan.empty or start_index_datsun.empty or start_index_infiniti.empty or start_index_total.empty:
        raise ValueError("One or more required terms ('nissan nv', 'datsun nv', 'infiniti nv') not found in the specified columns.")
    
    # Define a function to find indices within a range
    def find_indices_in_range(start_index):
        end_index = start_index + 8
        fmi_index = df.iloc[start_index:end_index][df.iloc[start_index:end_index].isin(['FMI']).any(axis=1)].index
        turnover_index = df.iloc[start_index:end_index][df.iloc[start_index:end_index].isin(['TurnoverAj']).any(axis=1)].index
        cos_index = df.iloc[start_index:end_index][df.iloc[start_index:end_index].isin(['COS Regional']).any(axis=1)].index
        vme_index = df.iloc[start_index:end_index][df.iloc[start_index:end_index].isin(['VME']).any(axis=1)].index
        
        # Return indices as a tuple if all are found, otherwise return None
        if not fmi_index.empty and not turnover_index.empty and not cos_index.empty and not vme_index.empty:
            return (fmi_index[0], turnover_index[0], cos_index[0], vme_index[0])
        else:
            return None
    
    # Find indices for each term
    indices_nissan = find_indices_in_range(start_index_nissan[0])
    indices_datsun = find_indices_in_range(start_index_datsun[0])
    indices_infiniti = find_indices_in_range(start_index_infiniti[0])
    indices_total=find_indices_in_range(start_index_total[0])
    
    # Check if indices are found for all terms
    if indices_nissan is None or indices_datsun is None or indices_infiniti is None:
        raise ValueError("Required indices not found within the specified range for one or more terms.")
    
    # Unpack and return all indices
    return (*indices_nissan, *indices_datsun, *indices_infiniti,*indices_total)



