def find_indices_feuil(df, month_number):
    # Convert dataframe to lowercase for case-insensitive search using DataFrame.map
    df_lower = df.apply(lambda row: row.map(lambda x: x.lower() if isinstance(x, str) else x), axis=1)
    
    # Find the row index for "ne total"
    try:
        row_index = df_lower[df_lower.apply(lambda row: 'ne total' in row.values, axis=1)].index[0]
    except IndexError:
        raise ValueError("The term 'NE Total' was not found in the dataframe.")
    
    # Create a dictionary mapping month numbers to month names
    month_dict = {
        1: "Jan", 2: "Feb", 3: "Mar", 4: "Apr",
        5: "May", 6: "Jun", 7: "Jul", 8: "Aug",
        9: "Sep", 10: "Oct", 11: "Nov", 12: "Dec"
    }
    
    # Get the month name from the dictionary
    month_name = month_dict.get(month_number)
    if not month_name:
        raise ValueError(f"Invalid month number '{month_number}'. Please provide a number between 1 and 12.")
    
    # Find the column index for the given month anywhere in the dataframe
    try:
        column_index = df_lower.apply(lambda row: month_name.lower() in row.values, axis=1).idxmax()
    except ValueError:
        raise ValueError(f"The month '{month_name}' was not found in the dataframe.")
    
    return row_index, column_index
    
