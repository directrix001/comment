def _empty_df() -> pd.DataFrame:
    return pd.DataFrame()


def _safe_read_excel_all_sheets(path: str, label: str) -> dict:
    if not path or not os.path.isfile(path):
        ui_log(f"  ↳ SKIP  {label}: file absent – empty data.", 'info')
        return {}
    try:
        ui_log(f"  ↳ READ  {label} …", 'info')
        sheets = pd.read_excel(path, sheet_name=None, engine="openpyxl")
        ui_log(f"  ↳ OK    {label}: {len(sheets)} sheet(s) loaded.", 'ok')
        return sheets
    except Exception as e:
        ui_log(f"  ↳ WARN  {label}: read failed ({e}) – empty data.", 'warn')
        return {}


def _safe_sheet(sheets_dict: dict, sheet_name: str, label: str) -> pd.DataFrame:
    if not sheets_dict:
        return _empty_df()
    if sheet_name in sheets_dict:
        return sheets_dict[sheet_name]
    lower_map = {k.lower(): k for k in sheets_dict}
    if sheet_name.lower() in lower_map:
        return sheets_dict[lower_map[sheet_name.lower()]]
    ui_log(f"  ↳ SKIP  {label} / '{sheet_name}' – sheet absent.", 'info')
    return _empty_df()


