def _set_file_status(key: str, found: bool):
    if key not in _file_status_vars:
        return
    e = _file_status_vars[key]
    if found:
        e["icon_var"].set(" ✔  ")
        e["icon_lbl"].config(fg="#a6e3a1")
        e["desc_lbl"].config(fg="#a6e3a1")
    else:
        colour = "#f38ba8" if key in REQUIRED_KEYS else "#f9e2af"
        e["icon_var"].set(" ✘  ")
        e["icon_lbl"].config(fg=colour)
        e["desc_lbl"].config(fg=colour)


def _reset_file_statuses():
    for e in _file_status_vars.values():
        e["icon_var"].set(" —  ")
        e["icon_lbl"].config(fg="#6c7a8d")
        e["desc_lbl"].config(fg="#6c7a8d")


def _refresh_file_status_from_folder(folder_path: str):
    _reset_file_statuses()
    if not folder_path or not os.path.isdir(folder_path):
        _status_summary_var.set("Folder not found")
        return
    try:
        fnames = os.listdir(folder_path)
    except PermissionError:
        _status_summary_var.set("Permission denied reading folder")
        return

    for key, kw, _, _ in FILE_META:
        _set_file_status(key, any(kw in f for f in fnames))

    found_count = sum(1 for _, kw, _, _ in FILE_META if any(kw in f for f in fnames))
    req_found   = sum(1 for _, kw, req, _ in FILE_META if req and any(kw in f for f in fnames))
    req_total   = len(REQUIRED_KEYS)
    _status_summary_var.set(
        f"Found {found_count}/{len(FILE_META)} files  |  Required: {req_found}/{req_total}"
    )


