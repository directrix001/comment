def validate_inputs() -> bool:
    fields = {
        "Input Folder":     file_path_entry.get().strip(),
        "Output Folder":    output_path_entry.get().strip(),
        "FX Converter":     converter_var_entry.get().strip(),
        "Month":            month_dropdown.get(),
        "CFMI":             converter_cfmi.get().strip(),
        "Café Penalty":     cafe_penalty_var.get().strip(),
        "Connectivity":     connectivity_var.get().strip(),
        "ePWR Step2":       ePWR_var.get().strip(),
        "mEUR G&A reclass": converter_mEUR.get().strip(),
        "bJPY G&A reclass": converter_bJPY.get().strip(),
    }
    missing = [k for k, v in fields.items() if not v]
    if month_dropdown.current() == -1 and "Month" not in missing:
        missing.insert(0, "Month")
    if missing:
        messagebox.showerror("Input Error",
            "The following fields are mandatory:\n• " + "\n• ".join(missing))
        return False

    numeric_fields = {
        "FX Converter":     converter_var_entry.get().strip(),
        "CFMI":             converter_cfmi.get().strip(),
        "Café Penalty":     cafe_penalty_var.get().strip(),
        "Connectivity":     connectivity_var.get().strip(),
        "ePWR Step2":       ePWR_var.get().strip(),
        "mEUR G&A reclass": converter_mEUR.get().strip(),
        "bJPY G&A reclass": converter_bJPY.get().strip(),
    }
    bad = [n for n, v in numeric_fields.items() if not _is_float(v)]
    if bad:
        messagebox.showerror("Invalid Numbers",
            "These fields must be numeric:\n• " + "\n• ".join(bad))
        return False
    return True

def _is_float(s: str) -> bool:
    try:
        float(s); return True
    except ValueError:
        return False


