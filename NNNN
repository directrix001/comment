def load_converter_data(_event=None):
    try:
        fp = os.path.join(base_dir, 'Mandatory_folder', 'currency_converter.xlsx')
        # Only clear numeric entries, NEVER touch path entries
        _clear_numeric_entries()
        if not os.path.isfile(fp):
            messagebox.showinfo("Converter Data",
                "currency_converter.xlsx not found.\nEnter FX rate manually.")
            return
        df  = pd.read_excel(fp)
        idx = month_dropdown.current() + 1
        val = df.iloc[0, idx]
        if pd.notna(val):
            converter_var_entry.insert(0, val)
            messagebox.showinfo("Converter Data",
                f"Pre-loaded FX rate for {month_dropdown.get()} ({df.iloc[0, 0]}).\nPlease verify.")
        else:
            messagebox.showinfo("Converter Data",
                f"No FX rate stored for {month_dropdown.get()}.\nEnter manually.")
    except Exception as e:
        messagebox.showerror("Error", f"Failed to load converter data: {e}")


