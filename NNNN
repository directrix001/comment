    except Exception as e:
        _hard_stop("Resolving Template Paths", e)
        return

    # ── Scan input folder ─────────────────────────────────────────────────────
    try:
        _phase("PHASE 3 / 4  –  Scanning Input Folder")
        file_paths: dict = {k: None for k in ALL_KEYS}
        keyword_map = {k: kw for k, kw, _, _ in FILE_META}

        if folder_path and os.path.isdir(folder_path):
            for fname in os.listdir(folder_path):
                for key, kw in keyword_map.items():
                    if kw in fname and file_paths[key] is None:
                        file_paths[key] = os.path.join(folder_path, fname)
                        ui_log(f"  ✔  Found  [{key}]  →  {fname}", 'ok')
        else:
            ui_log("  ✘  Input folder not accessible – all sources will be empty.", 'warn')

        for k, v in file_paths.items():
            if v is None:
                marker = "[REQUIRED]" if k in REQUIRED_KEYS else "[optional]"
                ui_log(f"  –  Missing {marker} {k}  →  empty DataFrame", 'warn' if k in REQUIRED_KEYS else 'info')

        # Update checklist panel (thread-safe via after())
        for key in ALL_KEYS:
            root.after(0, _set_file_status, key, file_paths[key] is not None)
    except Exception as e:
        _hard_stop("Scanning Input Folder", e)
        return

    if _stop_event.is_set():
        root.after(0, _ui_cancelled)
        return

    # ── Copy P&L template ─────────────────────────────────────────────────────
    try:
        _phase("PHASE 3b / 4  –  Preparing Working Copy")
        temp_dir = os.path.join(base_dir, 'Temp_files')
        if file_paths["P&L Summary"] and os.path.isfile(file_paths["P&L Summary"]):
            ui_log("  Copying P&L Summary to Temp_files …", 'info')
            copied_path = copy_excel_file(file_paths["P&L Summary"], temp_dir)
            if not copied_path:
                ui_log("  Copy failed – falling back to template.", 'warn')
                copied_path = file_path_template
        else:
            ui_log("  P&L Summary absent – using mandatory template as base.", 'warn')
            copied_path = file_path_template

        copy_master_sheet(file_paths["OSP Calc Tool"], copied_path, "jeanluc")
    except Exception as e:
        _hard_stop("Preparing Working Copy", e)
        return

    # ── Load all DataFrames ───────────────────────────────────────────────────
    try:
        _phase("PHASE 3c / 4  –  Loading DataFrames")

        def _load(key): return _safe_read_excel_all_sheets(file_paths[key], key)

        pl_summary_sheets     = _load("P&L Summary")
        hq_items_sheets       = _load("HQ items")
        osp_calc_sheets       = _load("OSP Calc Tool")
        hfm_mgr_sheets        = _load("HFM Managerial P&L")
        new_kpi_sheets        = _load("New KPI P&L")
        goodwill_sheets       = _load("Goodwill")
        osp_tgk_sheets        = _load("OSP TGK")
        high_level_var_sheets = _load("High_Level_Variance")
        relief_kd_sheets      = _load("Relief_KD")
        purchase_price_sheets = _load("Purchase_Price")
        up_calc_sheets        = _load("UP_Calc_Template_Simulation")
        nano_hfm_sheets       = _load("NANO_HFM")
        itp_sheets            = _load("ITP")

        ui_log("  Extracting individual sheets …", 'info')

        def _sh(d, sn, lbl): return _safe_sheet(d, sn, lbl)

        df_p_l_rop_ne   = _sh(pl_summary_sheets,     'ROP NE (Tagetik)',   "P&L Summary")
        df_p_l_hq       = _sh(pl_summary_sheets,     'HQ Tagetik',         "P&L Summary")
        df_mz_conso     = _sh(pl_summary_sheets,     'MZ conso TGK',       "P&L Summary")
        df_r_and_d      = _sh(pl_summary_sheets,     'R&D',                "P&L Summary")
        df_p_l_new_kpi  = _sh(pl_summary_sheets,     'New KPI Actual',     "P&L Summary")
        df_p_l_relief   = _sh(pl_summary_sheets,     'Relief',             "P&L Summary")
        df_p_l_pl       = _sh(pl_summary_sheets,     'P&L Actual',         "P&L Summary")
        df_p_l_reclass  = _sh(pl_summary_sheets,     'Reclass',            "P&L Summary")
        df_p_l_mccp     = _sh(pl_summary_sheets,     'MCPP',               "P&L Summary")
        df_p_l_ocs      = _sh(pl_summary_sheets,     'OCS details',        "P&L Summary")
        df_hq_items     = _sh(hq_items_sheets,       'Sheet1',             "HQ items")
        df_osp          = _sh(osp_calc_sheets,       'Master',             "OSP Calc Tool")
        df_hmf_mgr      = _sh(hfm_mgr_sheets,        'Managerial',         "HFM Managerial P&L")
        df_new_kpi_cfmi = _sh(new_kpi_sheets,        'CFMI',               "New KPI P&L")
        df_act          = _sh(new_kpi_sheets,        'Act',                "New KPI P&L")
        df_new_goodwill = _sh(goodwill_sheets,       'GW Budget',          "Goodwill")
        df_1c_osp       = _sh(osp_tgk_sheets,        'Summary',            "OSP TGK")
        df_hi_var       = _sh(high_level_var_sheets, 'Feuil1',             "High_Level_Variance")
        df_relief_kd    = _sh(relief_kd_sheets,      'vs 2+10',            "Relief_KD")
        df_purchase     = _sh(purchase_price_sheets, 'Summary pivot',      "Purchase_Price")
        df_up_calc      = _sh(up_calc_sheets,        'UP_Calculation',     "UP_Calc_Template_Simulation")
        df_nano_hfm     = _sh(nano_hfm_sheets,       'Actual',             "NANO_HFM")
        df_itp          = _sh(itp_sheets,            'BP25',               "ITP")

        ui_log(f"  All DataFrames ready.", 'ok')
    except Exception as e:
        _hard_stop("Loading DataFrames", e)
        return

    if _stop_event.is_set():
        root.after(0, _ui_cancelled)
        return

    # ── Call calculation engine ───────────────────────────────────────────────
    _phase("PHASE 4 / 4  –  Running Calculation Engine")

    if not _HAS_SUBMIT2:
        ui_log("  ✘  Submit_2 module not found – engine unavailable.", 'warn')
        ui_log("  All DataFrames loaded.  Attach Submit_2.py to enable output.", 'warn')
    else:
        def _fp(k): return file_paths.get(k) or ""

        file_path_template_run   = copied_path
        file_path_template_1_run = file_paths["New KPI P&L"] or file_path_template_1

        try:
            ui_log("  Calling calculate_alternate_value_1 …", 'info')
            calculate_alternate_value_1(
                _fp("P&L Summary"),
                df_p_l_rop_ne, df_p_l_hq,
                _fp("OSP Calc Tool"), df_osp,
                _fp("HFM Managerial P&L"), df_hmf_mgr,
                _fp("New KPI P&L"), df_p_l_new_kpi,
                _fp("HQ items"), df_hq_items,
                _fp("Goodwill"),
                df_r_and_d, df_mz_conso, df_p_l_relief, df_p_l_pl,
                df_p_l_reclass, df_p_l_mccp, df_p_l_ocs,
                df_new_kpi_cfmi, df_new_goodwill, df_act,
                _fp("OSP TGK"), df_1c_osp,
                _fp("High_Level_Variance"), df_hi_var,
                _fp("Relief_KD"), df_relief_kd,
                _fp("Purchase_Price"), df_purchase,
                _fp("UP_Calc_Template_Simulation"), df_up_calc,
                _fp("NANO_HFM"), df_nano_hfm,
                _fp("ITP"), df_itp,
                file_path_template_run, file_path_template_1_run,
                selected_month, var_converter, var_cfmi,
                var_ePWR, var_connectivity, var_cafe_penalty,
                file_path_template_man_1, file_path_template_man,
                file_path_goodwill_template, output_path,
                var_converter_bJPY, var_converter_mEUR,
            )
            ui_log("  Engine returned successfully.", 'ok')
        except Exception as e:
            _hard_stop("Calculation Engine (calculate_alternate_value_1)", e)
            return

    # ── Wrap-up ───────────────────────────────────────────────────────────────
    _stop_event.set()
    elapsed = time.time() - start_time
    m, s = divmod(int(elapsed), 60)
    fmt = f"{m:02d}:{s:02d}"

    ui_log("", 'info')
    ui_log("═" * 55, 'ok')
    ui_log(f"  ✔  COMPLETED  –  {fmt} (mm:ss)", 'ok')
    ui_log("═" * 55, 'ok')

    root.after(0, _ui_done, fmt)


def _ui_done(fmt_time: str):
    progress_bar.stop()
    save_message_label.config(
        text=f"✔  Done! Files saved to output folder. Time: {fmt_time} (mm:ss).",
        fg="#a6e3a1")
    toggle_buttons(True)


def _ui_cancelled():
    progress_bar.stop()
    save_message_label.config(text="Operation cancelled.", fg="#f9e2af")
    toggle_buttons(True)


