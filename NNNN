#  THREAD-SAFE UI LOGGER
#  All background threads call ui_log(msg, tag).  It routes through
#  root.after() so tkinter is only touched from the main thread.
# ═══════════════════════════════════════════════════════════════════════════════
# tag colour map
_TAG_COLOURS = {
    'phase':   '#cba6f7',   # purple  – major phase header
    'step':    '#7aa2f7',   # blue    – normal step
    'info':    '#6c7a8d',   # grey    – verbose detail
    'ok':      '#a6e3a1',   # green   – success line
    'warn':    '#f9e2af',   # yellow  – soft warning
    'error':   '#f38ba8',   # red     – error / hard stop
    'success': '#a6e3a1',   # alias
}

def ui_log(message: str, tag: str = 'step'):
    """Thread-safe: schedule a log append on the main thread."""
    root.after(0, _do_log, message, tag)

def _do_log(message: str, tag: str):
    ts = datetime.now().strftime('%H:%M:%S')
    log_text.configure(state='normal')
    log_text.insert(tk.END, f'[{ts}] {message}\n', tag)
    log_text.see(tk.END)

# Keep backward-compat alias used by other helpers
def log_step(message: str, tag: str = 'step'):
    ui_log(message, tag)


# ═══════════════════════════════════════════════════════════════════════════════
#  HARD-STOP helper  –  call from any thread on unexpected error
# ═══════════════════════════════════════════════════════════════════════════════
def _hard_stop(context: str, exc: Exception):
    """
    Log the full traceback to the log panel, show a red banner,
    stop the progress bar, re-enable buttons.
    Must be called from the background thread – uses root.after for UI.
    """
    tb = traceback.format_exc()
    ui_log("━" * 60, 'error')
    ui_log(f"❌  FATAL ERROR in: {context}", 'error')
    ui_log(f"    {type(exc).__name__}: {exc}", 'error')
    # Log each traceback line individually so they wrap nicely
    for line in tb.splitlines():
        ui_log(f"    {line}", 'error')
    ui_log("━" * 60, 'error')
    _stop_event.set()
    root.after(0, _ui_on_fatal, f"Error in {context}: {type(exc).__name__}: {exc}")

def _ui_on_fatal(msg: str):
    """Main-thread side of hard_stop."""
    progress_bar.stop()
    save_message_label.config(
        text=f"❌ Processing stopped – see log for details.",
        fg="#f38ba8"
    )
    toggle_buttons(True)
    logger.error(msg)


