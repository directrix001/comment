# We store one StringVar per file for the status icon and one for colour tag
_file_status_vars: dict = {}   # key → {"icon": StringVar, "label": tk.Label}


def _build_file_status_panel(parent):
    """Create the colour-coded checklist rows inside *parent*."""
    global _file_status_vars
    _file_status_vars = {}

    headers = tk.Frame(parent, bg="#1e2533")
    headers.pack(fill='x', padx=4, pady=(4, 2))
    tk.Label(headers, text="File", bg="#1e2533", fg="#8892a4",
             font=("Consolas", 8, "bold"), width=26, anchor='w').pack(side='left')
    tk.Label(headers, text="Status", bg="#1e2533", fg="#8892a4",
             font=("Consolas", 8, "bold"), width=9, anchor='w').pack(side='left')
    tk.Label(headers, text="Description", bg="#1e2533", fg="#8892a4",
             font=("Consolas", 8, "bold"), anchor='w').pack(side='left', fill='x', expand=True)

    ttk.Separator(parent, orient='horizontal').pack(fill='x', padx=4, pady=2)

    for key, _, required, desc in FILE_META:
        row = tk.Frame(parent, bg="#1e2533")
        row.pack(fill='x', padx=4, pady=1)

        req_tag = " ★" if required else "  "
        lbl_name = tk.Label(row, text=f"{req_tag}{key}", bg="#1e2533",
                            fg="#cdd6f4", font=("Consolas", 8), width=26, anchor='w')
        lbl_name.pack(side='left')

        icon_var = tk.StringVar(value="  —  ")
        lbl_icon = tk.Label(row, textvariable=icon_var, bg="#1e2533",
                            fg="#6c7a8d", font=("Consolas", 8, "bold"), width=9, anchor='w')
        lbl_icon.pack(side='left')

        lbl_desc = tk.Label(row, text=desc, bg="#1e2533",
                            fg="#6c7a8d", font=("Consolas", 8), anchor='w')
        lbl_desc.pack(side='left', fill='x', expand=True)

        _file_status_vars[key] = {"icon_var": icon_var, "icon_lbl": lbl_icon, "desc_lbl": lbl_desc}

    tk.Label(parent, text="  ★ = Required for output", bg="#1e2533",
             fg="#6c7a8d", font=("Consolas", 7), anchor='w').pack(anchor='w', padx=6, pady=(4, 2))


def _set_file_status(key: str, found: bool):
    """Update one row: green tick = found, red cross = missing."""
    if key not in _file_status_vars:
        return
    entry = _file_status_vars[key]
    if found:
        entry["icon_var"].set("  ✔  ")
        entry["icon_lbl"].config(fg="#a6e3a1")   # green
        entry["desc_lbl"].config(fg="#a6e3a1")
    else:
        required = key in REQUIRED_KEYS
        entry["icon_var"].set("  ✘  ")
        entry["icon_lbl"].config(fg="#f38ba8" if required else "#f9e2af")  # red / yellow
        entry["desc_lbl"].config(fg="#f38ba8" if required else "#f9e2af")


def _reset_file_statuses():
    for key in _file_status_vars:
        entry = _file_status_vars[key]
        entry["icon_var"].set("  —  ")
        entry["icon_lbl"].config(fg="#6c7a8d")
        entry["desc_lbl"].config(fg="#6c7a8d")


def _refresh_file_status_from_folder(folder_path: str):
    """Scan folder and immediately update the panel."""
    _reset_file_statuses()
    if not folder_path or not os.path.isdir(folder_path):
        return
    try:
        fnames = os.listdir(folder_path)
    except PermissionError:
        return

    for key, kw, _, _ in FILE_META:
        found = any(kw in f for f in fnames)
        _set_file_status(key, found)

    # Update summary badge
    found_count  = sum(1 for k, kw, _, _ in FILE_META if any(kw in f for f in fnames))
    req_found    = sum(1 for k, kw, req, _ in FILE_META if req and any(kw in f for f in fnames))
    req_total    = len(REQUIRED_KEYS)
    _status_summary_var.set(
        f"Found {found_count}/{len(FILE_META)} files  |  "
        f"Required: {req_found}/{req_total}"
    )


