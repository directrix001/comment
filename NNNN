def copy_excel_file(source_path: str, dest_folder: str):
    if not os.path.isfile(source_path):
        raise FileNotFoundError(f"Source not found: {source_path}")
    os.makedirs(dest_folder, exist_ok=True)
    base_name, ext = os.path.splitext(os.path.basename(source_path))
    dest = os.path.join(dest_folder, os.path.basename(source_path))
    counter = 1
    while os.path.exists(dest):
        dest = os.path.join(dest_folder, f"{base_name}_{counter}{ext}")
        counter += 1
    shutil.copy2(source_path, dest)
    ui_log(f"  ↳ Copied → {os.path.basename(dest)}", 'info')
    return dest


def copy_master_sheet(src_path: str, dest_path: str, password: str):
    if not src_path or not os.path.isfile(src_path):
        ui_log("  ↳ SKIP  Master sheet: OSP Calc Tool absent.", 'info')
        return
    try:
        ui_log("  ↳ Copying Master sheet from OSP Calc Tool …", 'info')
        df = pd.read_excel(src_path, sheet_name='Master', engine='openpyxl')
        wb = openpyxl.load_workbook(dest_path, keep_links=True)
        from openpyxl.workbook.protection import WorkbookProtection
        wb.security = WorkbookProtection(workbookPassword=password, lockStructure=True)
        if 'Master' in wb.sheetnames:
            del wb['Master']
        ws = wb.create_sheet(title='Master')
        for c, col in enumerate(df.columns, 1):
            ws.cell(row=1, column=c, value=col)
        for r, row in df.iterrows():
            for c, val in enumerate(row, 1):
                ws.cell(row=r + 2, column=c, value=val)
        wb.save(dest_path)
        ui_log("  ↳ OK    Master sheet written.", 'ok')
    except KeyError:
        ui_log("  ↳ SKIP  'Master' sheet not found in OSP Calc Tool.", 'warn')
    except Exception as e:
        ui_log(f"  ↳ WARN  Master sheet copy failed ({e}) – continuing.", 'warn')


# ═══════════════════════════════════════════════════════════════════════════════
#  ENCRYPTED-XLSX READER
# ═══════════════════════════════════════════════════════════════════════════════
def read_xlsx_openpyxl(path: str, sheet_name=None, password=None,
                       return_all_sheets: bool = False):
    if not os.path.isfile(path):
        raise FileNotFoundError(f"Excel file not found: {path}")
    ext = os.path.splitext(path)[1].lower()
    if ext not in ('.xlsx', '.xlsm'):
        raise ValueError(f"Unsupported format: {ext}")
    if isinstance(sheet_name, str):
        sheet_name = sheet_name.replace("&amp;", "&")
    with open(path, "rb") as f:
        office_file = msoffcrypto.OfficeFile(f)
        encrypted = getattr(office_file, "is_encrypted", False)
        if encrypted:
            if not password:
                raise ValueError("Workbook is encrypted – provide a password.")
            buf = io.BytesIO()
            office_file.load_key(password=password)
            office_file.decrypt(buf)
            buf.seek(0)
            return pd.read_excel(
                buf,
                sheet_name=None if return_all_sheets else sheet_name,
                engine='openpyxl')
    return pd.read_excel(path,
                         sheet_name=None if return_all_sheets else sheet_name,
                         engine='openpyxl')


