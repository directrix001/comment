    df_p_l_mccp     = _safe_sheet(pl_summary_sheets,     'MCPP',               "P&L Summary")
    df_p_l_ocs      = _safe_sheet(pl_summary_sheets,     'OCS details',        "P&L Summary")
    df_hq_items     = _safe_sheet(hq_items_sheets,       'Sheet1',             "HQ items")
    df_osp          = _safe_sheet(osp_calc_sheets,       'Master',             "OSP Calc Tool")
    df_hmf_mgr      = _safe_sheet(hfm_mgr_sheets,        'Managerial',         "HFM Managerial P&L")
    df_new_kpi_cfmi = _safe_sheet(new_kpi_sheets,        'CFMI',               "New KPI P&L")
    df_act          = _safe_sheet(new_kpi_sheets,        'Act',                "New KPI P&L")
    df_new_goodwill = _safe_sheet(goodwill_sheets,       'GW Budget',          "Goodwill")
    df_1c_osp       = _safe_sheet(osp_tgk_sheets,        'Summary',            "OSP TGK")
    df_hi_var       = _safe_sheet(high_level_var_sheets, 'Feuil1',             "High_Level_Variance")
    df_relief_kd    = _safe_sheet(relief_kd_sheets,      'vs 2+10',            "Relief_KD")
    df_purchase     = _safe_sheet(purchase_price_sheets, 'Summary pivot',      "Purchase_Price")
    df_up_calc      = _safe_sheet(up_calc_sheets,        'UP_Calculation',     "UP_Calc_Template_Simulation")
    df_nano_hfm     = _safe_sheet(nano_hfm_sheets,       'Actual',             "NANO_HFM")
    df_itp          = _safe_sheet(itp_sheets,            'BP25',               "ITP")

    if _stop_event.is_set():
        save_message_label.config(text="Operation cancelled.", fg="orange")
        progress_bar.stop()
        toggle_buttons(True)
        return

    file_path_template_run   = copied_path
    file_path_template_1_run = file_paths["New KPI P&L"] or file_path_template_1

    def _fp(key: str) -> str:
        return file_paths.get(key) or ""

    var_failure = False

    if not _HAS_SUBMIT2:
        log_step("[WARN] Submit_2 module not found – calculation engine unavailable.", "info")
        log_step("All DataFrames loaded successfully. Ready when engine is present.", "info")
    else:
        try:
            calculate_alternate_value_1(
                _fp("P&L Summary"),
                df_p_l_rop_ne, df_p_l_hq,
                _fp("OSP Calc Tool"), df_osp,
                _fp("HFM Managerial P&L"), df_hmf_mgr,
                _fp("New KPI P&L"), df_p_l_new_kpi,
                _fp("HQ items"), df_hq_items,
                _fp("Goodwill"),
                df_r_and_d, df_mz_conso, df_p_l_relief, df_p_l_pl,
                df_p_l_reclass, df_p_l_mccp, df_p_l_ocs,
                df_new_kpi_cfmi, df_new_goodwill, df_act,
                _fp("OSP TGK"), df_1c_osp,
                _fp("High_Level_Variance"), df_hi_var,
                _fp("Relief_KD"), df_relief_kd,
                _fp("Purchase_Price"), df_purchase,
                _fp("UP_Calc_Template_Simulation"), df_up_calc,
                _fp("NANO_HFM"), df_nano_hfm,
                _fp("ITP"), df_itp,
                file_path_template_run, file_path_template_1_run,
                selected_month, var_converter, var_cfmi,
                var_ePWR, var_connectivity, var_cafe_penalty,
                file_path_template_man_1, file_path_template_man,
                file_path_goodwill_template, output_path,
                var_converter_bJPY, var_converter_mEUR,
            )
        except Exception as e:
            logger.exception("Calculation error")
            log_step("Calculation failed – please check inputs and re-run.", 'error')
            var_failure = True
            progress_bar.stop()
            save_message_label.config(text=f"Error: {e}", fg="#f38ba8")

    progress_bar.stop()
    _stop_event.set()

    elapsed = time.time() - start_time
    mins, secs = divmod(int(elapsed), 60)
    fmt_time = f"{mins:02d}:{secs:02d}"

    if not var_failure:
        logger.info(f"Calculation completed in {elapsed:.1f}s")
        log_step("Calculation completed successfully.", 'success')
        save_message_label.config(
            text=f"Done! Files saved to output folder. Time: {fmt_time} (mm:ss).",
            fg="#a6e3a1"
        )
    toggle_buttons(True)


