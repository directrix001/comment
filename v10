                    else:
                        raw_bytes = cg_upload.getvalue()
                        xls = pd.ExcelFile(_io.BytesIO(raw_bytes))
                        if len(xls.sheet_names) > 1:
                            chosen_sheet = st.selectbox("Select sheet", xls.sheet_names, key="cg_sheet")
                        else:
                            chosen_sheet = xls.sheet_names[0]
                        cg_df = pd.read_excel(_io.BytesIO(raw_bytes), sheet_name=chosen_sheet, engine="openpyxl")

                    st.success(f"✅ Loaded — {len(cg_df):,} rows × {len(cg_df.columns)} columns")
                    with st.expander("👁️  Preview uploaded data (top 20 rows)", expanded=False):
                        st.dataframe(cg_df.head(20), use_container_width=True, height=220)
                except Exception as e:
                    st.error(f"File load error: {e}")

    st.markdown('<hr class="va-divider">', unsafe_allow_html=True)

    # ── Section 3: Metric Configuration ─────────
    with st.expander("⚙️  Metric Configuration", expanded=True):

        if cg_df is not None:
            all_cols  = cg_df.columns.tolist()
            num_cols  = cg_df.select_dtypes(include=["number"]).columns.tolist()
            cat_cols  = cg_df.select_dtypes(include=["object", "string", "category"]).columns.tolist()

            mc1, mc2 = st.columns([1, 1])

            with mc1:
                st.markdown("**Variance Metric**")
                has_variance_col = st.checkbox(
                    "Variance column already present in data?",
                    value=True,
                    key="cg_has_var"
                )

                variance_col    = ""
                base_scenario   = ""
                compare_scenario = ""

                if has_variance_col:
                    # When using Tab 2 data, pre-select Δ (A-B)
                    tab2_delta_col = "Δ (A-B)" if "Δ (A-B)" in num_cols else None
                    preferred_var  = tab2_delta_col or next(
                        (c for c in num_cols if "var" in c.lower()), num_cols[0] if num_cols else None
                    )
                    var_idx = num_cols.index(preferred_var) if preferred_var in num_cols else 0
                    variance_col = st.selectbox(
                        "Select Variance Column",
                        num_cols,
                        index=var_idx,
                        key="cg_var_col"
                    )
                else:
                    st.caption("Variance will be calculated as (Base − Compare)")
                    base_scenario    = st.selectbox("Base Scenario Column",    num_cols, key="cg_base")
                    compare_scenario = st.selectbox("Compare Scenario Column", num_cols, key="cg_compare")

            with mc2:
                st.markdown("**Drill-Down Hierarchy**")
                # When using Tab 2 data, pre-populate with group_fields
                default_hierarchy = []
                if cg_src == "🔗  Use Tab 2 Pivot Data (auto)" and tab2_available:
                    gf = st.session_state.var_context.get("group_fields", [])
                    default_hierarchy = [c for c in gf if c in all_cols]
                else:
                    default_hierarchy = [c for c in cat_cols if c in all_cols]

                hierarchy = st.multiselect(
                    "Hierarchy Flow (left = top level → right = leaf reason)",
                    options=all_cols,
                    default=default_hierarchy,
                    key="cg_hierarchy",
                    help="The agent groups by the first column, drills through the middle levels, "
                         "and reports Top-5 drivers from the LAST column."
                )

                st.caption(
                    f"ℹ️  Selected {len(hierarchy)} level(s). "
                    "The agent will loop through top-5 values at each level."
                )
        else:
            st.info("Load a data source above to configure metrics.")

    st.markdown('<hr class="va-divider">', unsafe_allow_html=True)

    # ── Section 4: Run ───────────────────────────
    env_ok = all([
        os.getenv("AZURE_OPENAI_ENDPOINT"),
        os.getenv("AZURE_OPENAI_KEY"),
        os.getenv("AZURE_OPENAI_DEPLOYMENT"),
        os.getenv("AZURE_OPENAI_API_VERSION"),
    ])

    run_col, hint_col = st.columns([1, 3])
    with run_col:
        cg_run_btn = st.button(
            "🧠  Generate Commentary",
            key="cg_run_btn",
            disabled=(cg_df is None or not env_ok)
        )
    with hint_col:
        if not env_ok:
            st.markdown(
                '<span style="color:#dc2626;font-size:.8rem;">⚠️ Azure OpenAI env vars missing — see status panel above.</span>',
                unsafe_allow_html=True
            )
        elif cg_df is None:
            st.markdown(
                '<span style="color:#6b7fa3;font-size:.8rem;">Load data and configure metrics to enable commentary generation.</span>',
                unsafe_allow_html=True
            )
        else:
            st.markdown(
                '<span style="color:#059669;font-size:.8rem;">✅ Ready — click Generate Commentary to run the AI agent.</span>',
                unsafe_allow_html=True
            )

    if cg_run_btn:
        if not hierarchy:
            st.warning("Please select at least one column in the Hierarchy.")
        elif has_variance_col and not variance_col:
            st.warning("Please select a variance column.")
        elif not has_variance_col and (not base_scenario or not compare_scenario):
            st.warning("Please select both Base and Compare scenario columns.")
        else:
            # Clear previous results
            st.session_state.cg_report = None
            st.session_state.cg_trace  = None

            prog_cg = st.progress(0, text="🔄 Initialising LangGraph agent…")
            try:
                prog_cg.progress(15, text="📐 Building drill-down trace…")
                app_graph = _build_langgraph()

                prog_cg.progress(35, text="🧮 Running branched variance engine…")
                inputs = {
                    "df":               cg_df,
                    "hierarchy_cols":   hierarchy,
                    "has_variance_col": has_variance_col,
                    "variance_col":     variance_col,
                    "base_scenario":    base_scenario,
                    "compare_scenario": compare_scenario,
                    "path_trace":       [],
                    "final_summary":    "",
                }

                prog_cg.progress(60, text="🤖 Calling Azure OpenAI for synthesis…")
                result = app_graph.invoke(inputs)

                prog_cg.progress(95, text="✨ Formatting report…")
                time.sleep(0.2)
                prog_cg.progress(100, text="✅ Commentary ready!")
                time.sleep(0.4)
                prog_cg.empty()

                st.session_state.cg_report = result.get("final_summary", "")
                st.session_state.cg_trace  = result.get("path_trace", [])
                st.toast("Commentary generated! Scroll down to view the report.", icon="📝")

            except Exception as e:
                prog_cg.empty()
                st.error(f"Commentary generation failed: {e}")

    # ── Section 5: Results ───────────────────────
    if st.session_state.cg_report:
        st.markdown('<hr class="va-divider">', unsafe_allow_html=True)

        # ── Executive Report Card ──
        st.markdown('<p class="va-section-label">📋 AI Executive Report</p>', unsafe_allow_html=True)

        is_error = (
            "aborted" in st.session_state.cg_report.lower() or
            "error" in st.session_state.cg_report.lower()
        )

        if is_error:
            st.error(st.session_state.cg_report)
        else:
            st.markdown(
                f'<div class="cg-report-wrap">{st.session_state.cg_report}</div>',
                unsafe_allow_html=True
            )

            dl1, dl2 = st.columns([1, 1])
            with dl1:
                st.download_button(
                    "📥 Download Executive Report (.md)",
                    data=st.session_state.cg_report,
                    file_name="executive_variance_commentary.md",
                    mime="text/markdown",
                    key="cg_dl_md"
                )
            with dl2:
                # Plain text version
                st.download_button(
                    "📥 Download as Plain Text (.txt)",
                    data=st.session_state.cg_report,
                    file_name="executive_variance_commentary.txt",
                    mime="text/plain",
                    key="cg_dl_txt"
                )

        # ── Drill-Down Trace ──
        st.markdown('<hr class="va-divider">', unsafe_allow_html=True)
        with st.expander("🧮  Branched Drill-Down Trace (raw calculation path)", expanded=False):
            st.caption(
                "The exact mathematical path the Pandas engine calculated before handing off to the LLM."
            )
            if st.session_state.cg_trace:
                for step in st.session_state.cg_trace:
                    step_s = str(step).strip()
                    if not step_s:
                        st.write("")
                        continue
                    if step_s.startswith("**Overall"):
                        st.markdown(
                            f'<div class="cg-trace-block primary">{step_s}</div>',
                            unsafe_allow_html=True
                        )
                    elif step_s.startswith("===") or step_s.startswith("🔹"):
                        st.markdown(
                            f'<div class="cg-trace-block primary">{step_s}</div>',
                            unsafe_allow_html=True
                        )
                    elif "FINAL LEVEL" in step_s:
                        st.markdown(
                            f'<div class="cg-trace-block final">{step_s}</div>',
                            unsafe_allow_html=True
                        )
                    elif step_s.startswith("---"):
                        st.markdown(
                            f'<div class="cg-trace-block">{step_s}</div>',
                            unsafe_allow_html=True
                        )
                    elif step_s.startswith("*=>"):
                        st.caption(step_s)
                    else:
                        st.text(step_s)
            else:
                st.info("No trace data available.")
